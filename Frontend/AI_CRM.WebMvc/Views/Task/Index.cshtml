@model IEnumerable<AI_CRM.Domain.Entities.TienDoDuAn>
@{
    ViewData["Title"] = "Tiến độ dự án";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-tasks me-2 text-primary"></i>Quản lý Tiến độ</h3>
    <a href="#" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-medium d-flex align-items-center gap-2">
        <i class="fa-solid fa-plus"></i> Cập nhật tiến độ
    </a>
</div>

<div class="glass-card p-4 border-0 shadow-sm rounded-4" style="background: #fff;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted" style="font-size: 0.85rem; text-transform: uppercase;">
                <tr>
                    <th class="ps-4 py-3 fw-bold border-bottom-0">Dự án</th>
                    <th class="py-3 fw-bold border-bottom-0">Tiến độ (%)</th>
                    <th class="py-3 fw-bold border-bottom-0">Ghi chú</th>
                    <th class="py-3 fw-bold border-bottom-0">Ngày cập nhật</th>
                    <th class="py-3 fw-bold border-bottom-0">Người cập nhật</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-bold text-dark">@(item.DuAn?.ProjectName ?? "Không rõ")</td>
                            <td class="py-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 8px;">
                                        <div class="progress-bar bg-success rounded-pill" style="width: @(item.ProgressPercent ?? 0)%"></div>
                                    </div>
                                    <span class="small fw-bold">@(item.ProgressPercent ?? 0)%</span>
                                </div>
                            </td>
                            <td class="py-3 text-muted">@item.Note</td>
                            <td class="py-3">@item.UpdateDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="py-3 fw-medium">@(item.NhanVienPhuTrach?.FullName ?? "Hệ thống")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-clipboard-list fs-1 mb-3 opacity-50"></i>
                            <p class="mb-0 fs-5">Chưa có nhật ký cập nhật tiến độ.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
