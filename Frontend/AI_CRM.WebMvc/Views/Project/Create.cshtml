@model AI_CRM.Domain.Entities.DuAn
@{
    ViewData["Title"] = "Thêm mới Dự án";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-project-diagram me-2 text-success"></i>Tạo Dự án mới</h3>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
    </a>
</div>

<div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white">
    <form>
        <div class="row g-4">
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Tên dự án</label>
                <input type="text" class="form-control bg-light border-0 shadow-none rounded-3 py-2" placeholder="Tên dự án phần mềm...">
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Khách hàng</label>
                <select class="form-select bg-light border-0 shadow-none rounded-3 py-2">
                    <option>-- Chọn khách hàng --</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Hợp đồng liên kết</label>
                <select class="form-select bg-light border-0 shadow-none rounded-3 py-2">
                    <option>-- Chọn hợp đồng --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Ngày bắt đầu</label>
                <input type="date" class="form-control bg-light border-0 shadow-none rounded-3 py-2">
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Deadline</label>
                <input type="date" class="form-control bg-light border-0 shadow-none rounded-3 py-2">
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Ngân sách (VNĐ)</label>
                <input type="number" class="form-control bg-light border-0 shadow-none rounded-3 py-2">
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Mô tả dự án</label>
                <textarea class="form-control bg-light border-0 shadow-none rounded-3 py-2" rows="4" placeholder="Chi tiết yêu cầu dự án..."></textarea>
            </div>
            <div class="col-12 text-end mt-4">
                <button type="button" class="btn btn-success rounded-pill px-5 py-2 shadow-sm fw-bold">
                    <i class="fa-solid fa-save me-2"></i> Khởi tạo Dự án
                </button>
            </div>
        </div>
    </form>
</div>
