@{
    ViewData["Title"] = "Tổng quan (Dashboard)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Tổng quan hệ thống</h3>
    <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-medium">
        <i class="fa-solid fa-plus me-2"></i>Dự án mới
    </button>
</div>

<!-- Stats Row -->
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="glass-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-muted mb-0 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Tổng Khách hàng</h6>
                <div class="stat-icon bg-primary-light">
                    <i class="fa-solid fa-building"></i>
                </div>
            </div>
            <h3 class="fw-bold mb-1">@ViewBag.TotalCustomers</h3>
            <span class="badge bg-success-light"><i class="fa-solid fa-arrow-up me-1"></i>12%</span>
            <span class="text-muted small ms-1">so với tháng trước</span>
        </div>
    </div>
    
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="glass-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-muted mb-0 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Dự án Đang chạy</h6>
                <div class="stat-icon bg-warning-light">
                    <i class="fa-solid fa-spinner fa-spin-pulse"></i>
                </div>
            </div>
            <h3 class="fw-bold mb-1">@ViewBag.ActiveProjects</h3>
            <span class="badge bg-danger-light"><i class="fa-solid fa-arrow-down me-1"></i>2</span>
            <span class="text-muted small ms-1">chậm tiến độ</span>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="glass-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-muted mb-0 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Hợp đồng Mới</h6>
                <div class="stat-icon bg-success-light">
                    <i class="fa-solid fa-file-signature"></i>
                </div>
            </div>
            <h3 class="fw-bold mb-1">@ViewBag.TotalContracts</h3>
            <span class="badge bg-success-light"><i class="fa-solid fa-arrow-up me-1"></i>5%</span>
            <span class="text-muted small ms-1">so với tháng trước</span>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="glass-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-muted mb-0 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Truy vấn Chatbot</h6>
                <div class="stat-icon" style="background-color: rgba(236, 72, 153, 0.1); color: var(--secondary-color);">
                    <i class="fa-solid fa-robot"></i>
                </div>
            </div>
            <h3 class="fw-bold mb-1">@ViewBag.ChatbotQueries</h3>
            <span class="text-muted small">tổng số câu hỏi tháng này</span>
        </div>
    </div>
</div>

<!-- Charts & Tables Row -->
<div class="row g-4">
    <!-- Chart -->
    <div class="col-12 col-lg-8">
        <div class="glass-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Tiến độ Dự án & Doanh thu</h5>
                <select class="form-select form-select-sm w-auto border-0 bg-light text-muted fw-medium">
                    <option>6 Tháng qua</option>
                    <option>Năm nay</option>
                </select>
            </div>
            <canvas id="revenueChart" height="100"></canvas>
        </div>
    </div>
    
    <!-- Activity Feed -->
    <div class="col-12 col-lg-4">
        <div class="glass-card p-4 h-100 d-flex flex-column">
            <h5 class="fw-bold mb-4">Hoạt động gần đây</h5>
            
            <div class="d-flex gap-3 mb-4">
                <div class="stat-icon bg-primary-light shadow-sm" style="width: 45px; height: 45px; font-size: 1.1rem; flex-shrink: 0;">
                    <i class="fa-solid fa-file-arrow-up"></i>
                </div>
                <div>
                    <h6 class="mb-1 fw-bold text-dark">Tài liệu Quy trình triển khai v2.pdf</h6>
                    <p class="text-muted small mb-0">Nguyễn Văn A đã tải lên • 2 giờ trước</p>
                </div>
            </div>
            
            <div class="d-flex gap-3 mb-4">
                <div class="stat-icon bg-success-light shadow-sm" style="width: 45px; height: 45px; font-size: 1.1rem; flex-shrink: 0;">
                    <i class="fa-solid fa-check-double"></i>
                </div>
                <div>
                    <h6 class="mb-1 fw-bold text-dark">Dự án CRM Phase 1 hoàn thành</h6>
                    <p class="text-muted small mb-0">Hệ thống ghi nhận • 5 giờ trước</p>
                </div>
            </div>
            
            <div class="d-flex gap-3 mb-4">
                <div class="stat-icon bg-warning-light shadow-sm" style="width: 45px; height: 45px; font-size: 1.1rem; flex-shrink: 0;">
                    <i class="fa-solid fa-phone"></i>
                </div>
                <div>
                    <h6 class="mb-1 fw-bold text-dark">Gọi điện KH: FPT Software</h6>
                    <p class="text-muted small mb-0">Trần Thị B • 1 ngày trước</p>
                </div>
            </div>

            <div class="d-flex gap-3 mb-4">
                <div class="stat-icon bg-danger-light shadow-sm" style="width: 45px; height: 45px; font-size: 1.1rem; flex-shrink: 0;">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div>
                    <h6 class="mb-1 fw-bold text-dark">Hợp đồng #HD-102 sắp hết hạn</h6>
                    <p class="text-muted small mb-0">Hệ thống cảnh báo • 2 ngày trước</p>
                </div>
            </div>
            
            <div class="mt-auto pt-3">
                <button class="btn btn-light text-primary fw-medium w-100 rounded-pill">Xem tất cả hoạt động</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const ctx = document.getElementById('revenueChart').getContext('2d');
        
        let gradient = ctx.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(79, 70, 229, 0.4)');
        gradient.addColorStop(1, 'rgba(79, 70, 229, 0.0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6'],
                datasets: [{
                    label: 'Doanh thu (Triệu VNĐ)',
                    data: [120, 190, 150, 280, 220, 350],
                    borderColor: '#4f46e5',
                    backgroundColor: gradient,
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#4f46e5',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        padding: 12,
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleFont: { size: 13, family: "'Inter', sans-serif" },
                        bodyFont: { size: 14, family: "'Inter', sans-serif" },
                        cornerRadius: 8,
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(0, 0, 0, 0.05)',
                            drawBorder: false,
                        },
                        ticks: {
                            font: { family: "'Inter', sans-serif" }
                        }
                    },
                    x: {
                        grid: {
                            display: false,
                            drawBorder: false,
                        },
                        ticks: {
                            font: { family: "'Inter', sans-serif" }
                        }
                    }
                },
                interaction: {
                    intersect: false,
                    mode: 'index',
                },
            }
        });
    </script>
}
