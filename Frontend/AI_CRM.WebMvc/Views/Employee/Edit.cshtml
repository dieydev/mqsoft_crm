@model AI_CRM.Domain.Entities.NhanVienPhuTrach
@{
    ViewData["Title"] = "Chỉnh sửa Nhân viên";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-user-pen me-2 text-warning"></i>Chỉnh sửa Nhân viên</h3>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="EmployeeId" />

                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="FullName" class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control" required />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-bold">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Department" class="form-label fw-bold">Phòng ban</label>
                        <input asp-for="Department" class="form-control" />
                        <span asp-validation-for="Department" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Position" class="form-label fw-bold">Chức vụ</label>
                        <input asp-for="Position" class="form-control" />
                        <span asp-validation-for="Position" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="UserId" class="form-label fw-bold">Tài khoản hệ thống (Tùy chọn)</label>
                        <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId">
                            <option value="">-- Không gắn tài khoản --</option>
                        </select>
                        <div class="form-text">Gắn tài khoản hệ thống để nhân viên có thể đăng nhập.</div>
                    </div>

                    <div class="col-md-12">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch">
                            <label class="form-check-label fw-bold" asp-for="IsActive">Đang hoạt động</label>
                        </div>
                    </div>
                </div>

                <hr class="my-4 text-muted">
                <div class="text-end">
                    <button type="submit" class="btn btn-warning rounded-pill px-5 shadow-sm fw-bold">
                        <i class="fa-solid fa-save me-2"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
