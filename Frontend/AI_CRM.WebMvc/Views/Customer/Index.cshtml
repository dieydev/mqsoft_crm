@model IEnumerable<AI_CRM.Domain.Entities.KhachHang>
@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark">Quản lý Khách hàng</h3>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-medium d-flex align-items-center gap-2">
        <i class="fa-solid fa-plus"></i> Thêm Khách hàng
    </a>
</div>

<div class="glass-card p-4 mb-4 border-0 shadow-sm rounded-4" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
    <div class="row g-3">
        <div class="col-md-5">
            <div class="input-group input-group-lg bg-light rounded-pill overflow-hidden border">
                <span class="input-group-text bg-transparent border-0 pe-1"><i class="fa-solid fa-search text-muted"></i></span>
                <input type="text" class="form-control border-0 bg-transparent shadow-none fs-6" placeholder="Tìm kiếm theo tên doanh nghiệp, sđt...">
            </div>
        </div>
        <div class="col-md-3">
            <select class="form-select form-select-lg border rounded-pill fs-6 text-muted">
                <option value="">Tất cả trạng thái</option>
                <option value="1">Đang hoạt động</option>
                <option value="2">Ngừng hoạt động</option>
            </select>
        </div>
        <div class="col-md-4 text-end d-flex justify-content-end gap-2">
            <button class="btn btn-outline-secondary rounded-pill px-4 fw-medium shadow-sm d-flex align-items-center gap-2">
                <i class="fa-solid fa-filter"></i> Lọc
            </button>
            <button class="btn btn-success rounded-pill px-4 fw-medium shadow-sm d-flex align-items-center gap-2">
                <i class="fa-solid fa-file-excel"></i> Xuất Excel
            </button>
        </div>
    </div>
</div>

<div class="glass-card overflow-hidden border-0 shadow-sm rounded-4" style="background: #fff;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" style="border-collapse: separate; border-spacing: 0;">
            <thead class="bg-light text-muted" style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px;">
                <tr>
                    <th class="ps-4 py-3 fw-bold border-bottom-0">Tên doanh nghiệp</th>
                    <th class="py-3 fw-bold border-bottom-0">Người đại diện</th>
                    <th class="py-3 fw-bold border-bottom-0">Email</th>
                    <th class="py-3 fw-bold border-bottom-0">Điện thoại</th>
                    <th class="py-3 fw-bold border-bottom-0">Địa chỉ</th>
                    <th class="text-end pe-4 py-3 fw-bold border-bottom-0">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var firstChar = !string.IsNullOrEmpty(item.CompanyName) ? item.CompanyName.Substring(0, 1).ToUpper() : "C";
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 45px; height: 45px; font-weight: 600; font-size: 1.2rem;">
                                        @firstChar
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-dark">@item.CompanyName</h6>
                                        @if (item.IsDeleted)
                                        {
                                            <span class="badge bg-danger-light text-danger fw-normal mt-1"><i class="fa-solid fa-circle text-danger" style="font-size: 8px; vertical-align: middle; margin-right: 4px;"></i>Đã xóa</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-light text-success fw-normal mt-1"><i class="fa-solid fa-circle text-success" style="font-size: 8px; vertical-align: middle; margin-right: 4px;"></i>Hoạt động</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="py-3 fw-medium">@(string.IsNullOrEmpty(item.Representative) ? "-" : item.Representative)</td>
                            <td class="py-3 text-muted">@(string.IsNullOrEmpty(item.Email) ? "-" : item.Email)</td>
                            <td class="py-3 fw-medium">@(string.IsNullOrEmpty(item.Phone) ? "-" : item.Phone)</td>
                            <td class="py-3 text-muted">@(string.IsNullOrEmpty(item.Address) ? "-" : item.Address)</td>
                            <td class="text-end pe-4 py-3">
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn btn-sm btn-light text-primary shadow-sm rounded-3 px-2 py-1" title="Xem chi tiết"><i class="fa-solid fa-eye"></i></button>
                                    <button class="btn btn-sm btn-light text-warning shadow-sm rounded-3 px-2 py-1" title="Chỉnh sửa"><i class="fa-solid fa-pen"></i></button>
                                    <button class="btn btn-sm btn-light text-danger shadow-sm rounded-3 px-2 py-1" title="Xóa"><i class="fa-solid fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            <i class="fa-solid fa-folder-open fs-2 mb-2"></i>
                            <p class="mb-0">Chưa có dữ liệu khách hàng. Hãy thêm khách hàng mới!</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="p-3 border-top d-flex justify-content-between align-items-center bg-light">
        <span class="text-muted small fw-medium">Hiển thị <span class="text-dark fw-bold">1 - 2</span> trong tổng số <span class="text-dark fw-bold">2</span> khách hàng</span>
        <nav>
            <ul class="pagination pagination-sm mb-0 shadow-sm gap-1">
                <li class="page-item disabled"><a class="page-link border-0 rounded-3 text-muted bg-transparent" href="#"><i class="fa-solid fa-chevron-left"></i></a></li>
                <li class="page-item active"><a class="page-link border-0 rounded-3 bg-primary text-white fw-bold" href="#">1</a></li>
                <li class="page-item"><a class="page-link border-0 rounded-3 text-dark bg-white" href="#">2</a></li>
                <li class="page-item"><a class="page-link border-0 rounded-3 text-dark bg-white" href="#">3</a></li>
                <li class="page-item"><a class="page-link border-0 rounded-3 text-dark bg-white" href="#"><i class="fa-solid fa-chevron-right"></i></a></li>
            </ul>
        </nav>
    </div>
</div>
