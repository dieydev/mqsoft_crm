@model IEnumerable<AI_CRM.Domain.Entities.TienDoDuAn>
@{
    ViewData["Title"] = "Quản lý tiến độ dự án";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-4" role="alert">
        <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-bars-progress me-2 text-warning"></i>Quản lý Tiến độ</h3>
    
    <div class="d-flex flex-column flex-md-row gap-2">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <select name="projectId" class="form-select rounded-pill px-3 shadow-sm border-0" asp-items="ViewBag.ProjectList">
                <option value="">-- Lọc theo dự án --</option>
            </select>
            <button type="submit" class="btn btn-secondary rounded-pill px-3 shadow-sm"><i class="fa-solid fa-search"></i> Lọc</button>
        </form>
        <a asp-action="Create" class="btn btn-warning text-dark rounded-pill px-4 shadow-sm fw-bold d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus"></i> Cập nhật tiến độ
        </a>
    </div>
</div>

<div class="glass-card p-0 border-0 shadow-sm rounded-4 bg-white overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted small text-uppercase">
                <tr>
                    <th class="ps-4 py-3">Dự án</th>
                    <th class="py-3">Mức độ hoàn thành</th>
                    <th class="py-3">Ghi chú</th>
                    <th class="py-3">Cập nhật lúc</th>
                    <th class="py-3">Người báo cáo</th>
                    <th class="text-end pe-4 py-3">Thao tác</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <a asp-controller="Project" asp-action="Details" asp-route-id="@item.ProjectId" class="fw-bold text-dark text-decoration-none">
                                    @(item.DuAn?.ProjectName ?? "-")
                                </a>
                            </td>
                            <td class="py-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar bg-success" role="progressbar" style="width: @(item.ProgressPercent ?? 0)%;"></div>
                                    </div>
                                    <span class="fw-bold text-success small">@(item.ProgressPercent ?? 0)%</span>
                                </div>
                            </td>
                            <td class="py-3 text-muted">
                                @item.Note
                            </td>
                            <td class="py-3">
                                <div class="fw-medium">@item.UpdateDate.ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td class="py-3">
                                <span class="badge bg-light text-dark border">@(item.NhanVienPhuTrach?.FullName ?? "Hệ thống")</span>
                            </td>
                            <td class="text-end pe-4 py-3">
                                <a asp-action="Edit" asp-route-id="@item.ProgressId" class="btn btn-sm btn-light text-warning rounded-circle me-1" title="Sửa"><i class="fa-solid fa-pen"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.ProgressId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bản cập nhật này?');">
                                    <button type="submit" class="btn btn-sm btn-light text-danger rounded-circle" title="Xóa"><i class="fa-solid fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-inbox fs-2 mb-3 opacity-50"></i>
                            <p class="mb-0">Chưa có dữ liệu tiến độ nào.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
