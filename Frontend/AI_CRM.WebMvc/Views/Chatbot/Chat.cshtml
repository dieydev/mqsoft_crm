@{
    ViewData["Title"] = "Trợ lý AI";
}

<div class="h-100 d-flex flex-column" style="min-height: 75vh;">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold mb-0 text-dark">
            <i class="fa-solid fa-wand-magic-sparkles me-2" style="color: #ec4899;"></i> MQSoft AI Assistant
        </h3>
        <span class="badge rounded-pill bg-success-light"><i class="fa-solid fa-circle text-success me-1" style="font-size:8px;"></i> AI is ready</span>
    </div>

    <!-- Chat Box -->
    <div class="glass-card flex-grow-1 border-0 shadow-sm rounded-4 bg-white d-flex flex-column overflow-hidden">
        <!-- Messages Area -->
        <div class="chat-messages p-4 flex-grow-1 overflow-auto bg-light" style="max-height: 60vh;">
            
            <!-- AI Welcome Message -->
            <div class="d-flex gap-3 mb-4">
                <div class="rounded-circle bg-white d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px;">
                    <i class="fa-solid fa-robot" style="color: #ec4899;"></i>
                </div>
                <div class="p-3 rounded-4 bg-white shadow-sm" style="max-width: 80%; border-top-left-radius: 0 !important;">
                    <p class="mb-0 text-dark fw-medium">Xin chào! Tôi là Trợ lý ảo của MQSoft CRM. Tôi đã đọc toàn bộ tài liệu nội bộ và dự án.</p>
                    <p class="mb-0 text-dark fw-medium mt-1">Bạn cần tôi tra cứu hợp đồng, tiến độ dự án hay quy trình nào hôm nay?</p>
                </div>
            </div>

            <!-- User Message Placeholder -->
            <div class="d-flex gap-3 mb-4 flex-row-reverse">
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px;">
                    <i class="fa-regular fa-user"></i>
                </div>
                <div class="p-3 rounded-4 bg-primary text-white shadow-sm" style="max-width: 80%; border-top-right-radius: 0 !important;">
                    <p class="mb-0 fw-medium">Cho tôi biết quy trình ký hợp đồng mới gồm những bước nào?</p>
                </div>
            </div>

            <!-- AI Response Placeholder -->
            <div class="d-flex gap-3 mb-4">
                <div class="rounded-circle bg-white d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px;">
                    <i class="fa-solid fa-robot" style="color: #ec4899;"></i>
                </div>
                <div class="p-3 rounded-4 bg-white shadow-sm" style="max-width: 80%; border-top-left-radius: 0 !important;">
                    <p class="mb-0 text-dark fw-medium">Dựa theo tài liệu "Quy trình triển khai v2.pdf", quy trình ký hợp đồng mới gồm 3 bước:</p>
                    <ul class="mb-0 mt-2 text-dark">
                        <li>Bước 1: Lập báo giá và chốt scope với khách hàng.</li>
                        <li>Bước 2: Soạn thảo hợp đồng theo mẫu HD-01.</li>
                        <li>Bước 3: Trình Giám đốc ký và đóng dấu.</li>
                    </ul>
                </div>
            </div>

        </div>

        <!-- Input Area -->
        <div class="p-3 bg-white border-top">
            <div class="input-group">
                <button class="btn btn-light border-0 shadow-none text-muted px-3 rounded-start-pill" type="button">
                    <i class="fa-solid fa-paperclip"></i>
                </button>
                <input type="text" class="form-control bg-light border-0 shadow-none py-3" placeholder="Hỏi AI bất cứ điều gì về dữ liệu của bạn...">
                <button class="btn btn-primary px-4 rounded-end-pill" type="button">
                    <i class="fa-solid fa-paper-plane me-2"></i> Gửi
                </button>
            </div>
            <div class="text-center mt-2">
                <small class="text-muted" style="font-size: 0.75rem;">AI có thể đưa ra thông tin không chính xác. Vui lòng kiểm tra lại tài liệu gốc.</small>
            </div>
        </div>
    </div>
</div>
