@model AI_CRM.Domain.Entities.TaiLieuNoiBo
@{
    ViewData["Title"] = "Upload Tài liệu";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-cloud-arrow-up me-2 text-primary"></i>Upload Tài liệu (Knowledge Base)</h3>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
    </a>
</div>

<div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white">
    <form>
        <div class="row g-4">
            <div class="col-md-12">
                <div class="border-2 border-dashed rounded-4 p-5 text-center bg-light" style="border-style: dashed; border-color: #cbd5e1;">
                    <i class="fa-solid fa-file-pdf fs-1 text-danger mb-3"></i>
                    <h5>Kéo thả file vào đây hoặc click để chọn</h5>
                    <p class="text-muted small">Hỗ trợ định dạng PDF, DOCX, TXT. Tối đa 50MB.</p>
                    <input type="file" class="form-control d-none" id="fileUpload">
                    <button type="button" class="btn btn-outline-primary rounded-pill px-4 mt-2" onclick="document.getElementById('fileUpload').click()">
                        Chọn File
                    </button>
                </div>
            </div>
            
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Tên tài liệu</label>
                <input type="text" class="form-control bg-light border-0 shadow-none rounded-3 py-2" placeholder="Tên hiển thị của tài liệu...">
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Nhóm tài liệu</label>
                <select class="form-select bg-light border-0 shadow-none rounded-3 py-2">
                    <option>Quy trình nội bộ</option>
                    <option>Tài liệu kỹ thuật</option>
                    <option>Hợp đồng mẫu</option>
                </select>
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Mô tả nội dung</label>
                <textarea class="form-control bg-light border-0 shadow-none rounded-3 py-2" rows="3" placeholder="Tóm tắt tài liệu..."></textarea>
            </div>
            <div class="col-12 mt-4 text-center">
                <button type="button" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">
                    <i class="fa-solid fa-upload me-2"></i> Tải lên & Huấn luyện AI
                </button>
            </div>
        </div>
    </form>
</div>
