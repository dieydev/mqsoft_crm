@model IEnumerable<AI_CRM.Domain.Entities.TaiLieuNoiBo>
@{
    ViewData["Title"] = "Tài liệu Nội bộ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-folder-open me-2 text-primary"></i>Tài liệu Nội bộ</h3>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-upload me-2"></i> Tải lên tài liệu
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 border-0" role="alert">
        <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label text-muted fw-bold small text-uppercase">Tìm kiếm</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-search text-muted"></i></span>
                <input type="text" name="searchString" class="form-control border-start-0 bg-light" placeholder="Tên tài liệu, mô tả..." value="@ViewBag.SearchString">
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label text-muted fw-bold small text-uppercase">Nhóm tài liệu</label>
            <select name="categoryId" class="form-select bg-light border-0" asp-items="ViewBag.Categories">
                <option value="">-- Tất cả nhóm --</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary px-4 w-100 rounded-3 shadow-sm fw-medium">Lọc</button>
        </div>
        <div class="col-md-2 text-end">
             @if (!string.IsNullOrEmpty(ViewBag.SearchString) || ViewBag.CurrentCategory != null)
             {
                 <a asp-action="Index" class="btn btn-outline-secondary w-100 rounded-3"><i class="fa-solid fa-rotate-left me-1"></i> Xóa lọc</a>
             }
        </div>
    </form>
</div>

<div class="row g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var doc in Model)
        {
            <div class="col-md-4">
                <div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white h-100 d-flex flex-column transition-hover position-relative">
                    <div class="position-absolute top-0 end-0 p-3">
                        <div class="dropdown">
                            <button class="btn btn-sm btn-light border-0 rounded-circle shadow-none" type="button" data-bs-toggle="dropdown">
                                <i class="fa-solid fa-ellipsis-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                <li><a class="dropdown-item" asp-action="Download" asp-route-id="@doc.DocumentId"><i class="fa-solid fa-download me-2 text-success"></i>Tải xuống</a></li>
                                <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@doc.DocumentId"><i class="fa-solid fa-pen me-2 text-warning"></i>Chỉnh sửa</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#" data-bs-toggle="modal" data-bs-target="#deleteModal-@doc.DocumentId"><i class="fa-solid fa-trash me-2"></i>Xóa</a></li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary-light p-3 rounded-4 me-3 text-center" style="width: 60px;">
                            @{
                                var icon = "fa-file";
                                if (doc.FilePath != null)
                                {
                                    if (doc.FilePath.EndsWith(".pdf")) icon = "fa-file-pdf text-danger";
                                    else if (doc.FilePath.EndsWith(".doc") || doc.FilePath.EndsWith(".docx")) icon = "fa-file-word text-primary";
                                    else if (doc.FilePath.EndsWith(".xls") || doc.FilePath.EndsWith(".xlsx")) icon = "fa-file-excel text-success";
                                }
                            }
                            <i class="fa-solid @icon fa-2x"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1 text-truncate" style="max-width: 180px;" title="@doc.Title">@doc.Title</h6>
                            <span class="badge bg-light text-dark border">@doc.NhomTaiLieu?.CategoryName</span>
                        </div>
                    </div>
                    
                    <p class="text-muted small mb-3 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                        @(string.IsNullOrEmpty(doc.Description) ? "Không có mô tả." : doc.Description)
                    </p>

                    <div class="mb-3">
                        @foreach(var tag in doc.TaiLieuTags)
                        {
                            <span class="badge rounded-pill bg-light text-primary border me-1"><i class="fa-solid fa-hashtag me-1"></i>@tag.TagName</span>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                        <div class="small text-muted">
                            <i class="fa-regular fa-clock me-1"></i> @doc.UploadDate.ToString("dd/MM/yyyy HH:mm")
                        </div>
                        <div class="small text-muted" title="Người tải lên: @(doc.NhanVienPhuTrach?.FullName)">
                            <i class="fa-regular fa-user me-1"></i> @(doc.NhanVienPhuTrach?.FullName ?? "N/A")
                        </div>
                    </div>
                </div>
                
                <!-- Delete Modal -->
                <div class="modal fade" id="deleteModal-@doc.DocumentId" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content rounded-4 border-0 shadow">
                            <div class="modal-body text-center p-4">
                                <div class="text-danger mb-3"><i class="fa-solid fa-triangle-exclamation fa-3x"></i></div>
                                <h5>Xóa tài liệu?</h5>
                                <p class="text-muted">Bạn có chắc chắn muốn xóa tài liệu <strong>@doc.Title</strong>? File vật lý trên server cũng có thể bị mất.</p>
                                <form asp-action="Delete" asp-route-id="@doc.DocumentId" method="post" class="d-flex justify-content-center gap-2">
                                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                                    <button type="submit" class="btn btn-danger rounded-pill px-4">Xóa</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <div class="glass-card p-5 border-0 shadow-sm rounded-4 bg-white">
                <i class="fa-regular fa-folder-open fa-4x text-muted mb-3"></i>
                <h5 class="fw-bold">Chưa có tài liệu nào</h5>
                <p class="text-muted">Không tìm thấy tài liệu phù hợp hoặc hệ thống chưa có dữ liệu.</p>
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4"><i class="fa-solid fa-upload me-2"></i> Tải lên ngay</a>
            </div>
        </div>
    }
</div>
