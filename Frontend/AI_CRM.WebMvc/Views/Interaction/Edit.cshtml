@model AI_CRM.Domain.Entities.LichSuLamViec
@{
    ViewData["Title"] = "Cập nhật nhật ký CSKH";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-pen me-2 text-warning"></i>Cập nhật Nhật ký CSKH</h3>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
    </a>
</div>

<div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="WorkLogId" />
        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Khách hàng <span class="text-danger">*</span></label>
                <select asp-for="CustomerId" class="form-select bg-light border-0 shadow-none rounded-3 py-2" asp-items="ViewBag.CustomerId" required>
                    <option value="">-- Chọn khách hàng --</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Nhân viên phụ trách <span class="text-danger">*</span></label>
                <select asp-for="EmployeeId" class="form-select bg-light border-0 shadow-none rounded-3 py-2" asp-items="ViewBag.EmployeeId" required>
                    <option value="">-- Chọn nhân viên --</option>
                </select>
                <span asp-validation-for="EmployeeId" class="text-danger small"></span>
            </div>
            
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Hình thức tương tác <span class="text-danger">*</span></label>
                <select asp-for="InteractionType" class="form-select bg-light border-0 shadow-none rounded-3 py-2" required>
                    <option value="">-- Chọn hình thức --</option>
                    <option value="Gọi điện">Gọi điện (Call)</option>
                    <option value="Email">Email</option>
                    <option value="Họp">Gặp mặt / Họp (Meeting)</option>
                    <option value="Khác">Khác</option>
                </select>
                <span asp-validation-for="InteractionType" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Thời gian thực hiện</label>
                <input asp-for="WorkDate" type="datetime-local" class="form-control bg-light border-0 shadow-none rounded-3 py-2" />
            </div>

            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Nội dung trao đổi <span class="text-danger">*</span></label>
                <textarea asp-for="Content" class="form-control bg-light border-0 shadow-none rounded-3 py-2" rows="4" required></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>
            
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Kết quả / Next Step</label>
                <textarea asp-for="Result" class="form-control bg-light border-0 shadow-none rounded-3 py-2" rows="2"></textarea>
            </div>
            
            <div class="col-12 text-end mt-4">
                <button type="submit" class="btn btn-warning text-dark rounded-pill px-5 py-2 shadow-sm fw-bold">
                    <i class="fa-solid fa-save me-2"></i> Lưu Thay đổi
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
