<!-- Giant Call To Action -->
<section id="appointment" class="py-5 mb-5 mt-5">
    <div class="container py-5" data-aos="zoom-in">
        <div class="bg-primary rounded-5 p-4 p-md-5 position-relative overflow-hidden shadow-lg text-center mx-auto" style="max-width: 1000px;">
            <!-- Abstract background shapes -->
            <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" style="background: radial-gradient(circle at top right, white, transparent 50%), radial-gradient(circle at bottom left, #0dcaf0, transparent 50%); z-index: 0;"></div>
            
            <div class="position-relative z-1 py-4 py-md-5">
                <span class="badge bg-white text-primary rounded-pill px-4 py-2 fs-6 fw-bold mb-4 shadow-sm">Bắt đầu ngay hôm nay</span>
                <h2 class="display-3 fw-bolder text-white mb-4 lh-sm">Sẵn sàng số hóa <br>phòng khám của bạn?</h2>
                <p class="text-white-50 fs-5 mb-5 mx-auto" style="max-width: 600px;">Để lại thông tin, đội ngũ kỹ sư MQSoft sẽ liên hệ tư vấn giải pháp và báo giá chi tiết hoàn toàn miễn phí.</p>
                
                <form class="bg-white p-2 rounded-pill shadow-lg d-flex flex-column flex-md-row mx-auto" style="max-width: 700px;">
                    <input type="text" class="form-control border-0 bg-transparent fs-5 px-4 shadow-none mb-2 mb-md-0" placeholder="Tên cơ sở y tế...">
                    <div class="vr mx-2 d-none d-md-block" style="opacity: 0.1;"></div>
                    <input type="tel" class="form-control border-0 bg-transparent fs-5 px-4 shadow-none mb-2 mb-md-0" placeholder="Số điện thoại...">
                    <button type="button" class="btn btn-dark rounded-pill px-5 py-3 fs-5 fw-bold ms-md-2 shadow-sm text-nowrap">Nhận Báo Giá</button>
                </form>
            </div>
        </div>
