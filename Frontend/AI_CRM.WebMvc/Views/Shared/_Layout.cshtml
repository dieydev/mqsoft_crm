<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI CRM System</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar shadow-lg">
        <div class="sidebar-header">
            <i class="fa-solid fa-layer-group"></i> AI CRM
        </div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link active" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-chart-pie w-20px"></i> Tổng quan
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="fa-solid fa-building w-20px"></i> Khách hàng
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="fa-solid fa-project-diagram w-20px"></i> Dự án
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="fa-solid fa-file-contract w-20px"></i> Hợp đồng
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="fa-solid fa-folder-open w-20px"></i> Tài liệu nội bộ
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="fa-solid fa-robot w-20px"></i> Trợ lý AI
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="fa-solid fa-users w-20px"></i> Nhân sự
                </a>
            </li>
        </ul>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Topbar -->
        <header class="topbar">
            <div class="search-bar d-flex align-items-center bg-light rounded-pill px-3 py-2 w-50">
                <i class="fa-solid fa-search text-muted me-2"></i>
                <input type="text" class="form-control border-0 bg-transparent shadow-none" placeholder="Tìm kiếm khách hàng, dự án, tài liệu...">
            </div>
            <div class="topbar-actions d-flex align-items-center gap-4">
                <a href="#" class="text-secondary position-relative">
                    <i class="fa-solid fa-bell fs-5"></i>
                    <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                        <span class="visually-hidden">New alerts</span>
                    </span>
                </a>
                <div class="user-profile d-flex align-items-center gap-2 dropdown" style="cursor:pointer" data-bs-toggle="dropdown">
                    <img src="https://ui-avatars.com/api/?name=Admin&background=4f46e5&color=fff" alt="User">
                    <div class="d-none d-md-block">
                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">Admin User</div>
                        <div class="text-muted" style="font-size: 0.8rem;">Quản trị viên</div>
                    </div>
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                    <li><a class="dropdown-item" href="#"><i class="fa-regular fa-user me-2"></i> Hồ sơ cá nhân</a></li>
                    <li><a class="dropdown-item" href="#"><i class="fa-solid fa-gear me-2"></i> Cài đặt</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="#"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Đăng xuất</a></li>
                </ul>
            </div>
        </header>

        <!-- Body -->
        <main class="p-4" style="flex: 1;">
            @RenderBody()
        </main>
        
        <footer class="text-center py-3 text-muted" style="font-size: 0.9rem;">
            &copy; 2026 - AI CRM System v1.0
        </footer>
    </div>

    <!-- AI Chatbot FAB -->
    <div class="chat-fab" title="Mở Trợ lý AI">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
