@model AI_CRM.Domain.Entities.NhanVienPhuTrach
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold mb-0">Hồ sơ cá nhân</h2>
            <p class="text-muted">Quản lý thông tin tài khoản của bạn</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body text-center p-4">
                    <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(User.Identity.Name ?? "User"))&background=4f46e5&color=fff&size=120" 
                         alt="User" class="rounded-circle mb-3 shadow-sm" style="width: 120px; height: 120px; border: 4px solid #fff;">
                    
                    <h4 class="fw-bold mb-1">@(User.Identity.Name ?? "Người dùng")</h4>
                    <p class="text-muted mb-3">@(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Chưa rõ vai trò")</p>
                    
                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <button class="btn btn-outline-primary btn-sm rounded-pill px-3"><i class="fa-solid fa-camera me-1"></i> Đổi ảnh</button>
                        <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger btn-sm rounded-pill px-3"><i class="fa-solid fa-arrow-right-from-bracket me-1"></i> Đăng xuất</a>
                    </div>
                    
                    <hr class="text-muted">
                    
                    <div class="d-flex justify-content-between align-items-center text-start mt-3">
                        <span class="text-muted small"><i class="fa-regular fa-calendar-check me-1"></i> Ngày tham gia:</span>
                        <span class="fw-medium small">@(Model?.NguoiDung?.CreatedDate.ToString("dd/MM/yyyy") ?? "Không có dữ liệu")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0">Thông tin chi tiết</h5>
                </div>
                <div class="card-body p-4">
                    <form>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-bold">Họ và tên</label>
                                <input type="text" class="form-control" value="@(Model?.FullName ?? User.Identity.Name)" readonly>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label class="form-label text-muted small fw-bold">Chức vụ</label>
                                <input type="text" class="form-control" value="@(Model?.Position ?? "Nhân viên")" readonly>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-bold">Email</label>
                                <input type="email" class="form-control" value="@Model?.Email" readonly>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label class="form-label text-muted small fw-bold">Số điện thoại</label>
                                <input type="text" class="form-control" value="@(Model?.Phone ?? "Chưa cập nhật")" readonly>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-12">
                                <label class="form-label text-muted small fw-bold">Bộ phận</label>
                                <input type="text" class="form-control" value="@(Model?.Department ?? "Chưa cập nhật")" readonly>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="button" class="btn btn-primary rounded-pill px-4" disabled><i class="fa-solid fa-save me-1"></i> Lưu thay đổi</button>
                            <small class="text-muted ms-3 align-self-center">*Tính năng chỉnh sửa đang phát triển</small>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold text-danger mb-0">Bảo mật tài khoản</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-4">Vì tài khoản của bạn được liên kết với Google Workspace của công ty, bạn không thể đổi mật khẩu tại đây. Vui lòng liên hệ IT để được hỗ trợ.</p>
                    <button class="btn btn-outline-secondary rounded-pill px-4" disabled><i class="fa-solid fa-key me-1"></i> Đổi mật khẩu</button>
                </div>
            </div>
        </div>
    </div>
</div>
