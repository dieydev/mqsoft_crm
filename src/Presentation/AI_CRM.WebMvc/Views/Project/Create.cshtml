@model AI_CRM.Domain.Entities.DuAn
@{
    ViewData["Title"] = "Thêm mới Dự án";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-project-diagram me-2 text-success"></i>Tạo Dự án mới</h3>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
    </a>
</div>

<div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white">
    <form asp-action="Create" method="post">
        <div class="row g-4">
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Tên dự án <span class="text-danger">*</span></label>
                <input asp-for="ProjectName" class="form-control bg-light border-0 shadow-none rounded-3 py-2" placeholder="Tên dự án phần mềm..." required />
                <span asp-validation-for="ProjectName" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Khách hàng <span class="text-danger">*</span></label>
                <select asp-for="CustomerId" class="form-select bg-light border-0 shadow-none rounded-3 py-2" asp-items="ViewBag.CustomerId" required>
                    <option value="">-- Chọn khách hàng --</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Hợp đồng liên kết</label>
                <select asp-for="ContractId" class="form-select bg-light border-0 shadow-none rounded-3 py-2" asp-items="ViewBag.ContractId">
                    <option value="">-- Chọn hợp đồng (tùy chọn) --</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Trạng thái <span class="text-danger">*</span></label>
                <select asp-for="StatusId" class="form-select bg-light border-0 shadow-none rounded-3 py-2" asp-items="ViewBag.StatusId" required>
                    <option value="">-- Chọn trạng thái --</option>
                </select>
                <span asp-validation-for="StatusId" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Ngày bắt đầu</label>
                <input asp-for="StartDate" type="date" class="form-control bg-light border-0 shadow-none rounded-3 py-2" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Deadline</label>
                <input asp-for="Deadline" type="date" class="form-control bg-light border-0 shadow-none rounded-3 py-2" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Ngân sách (VNĐ)</label>
                <input asp-for="Budget" type="number" class="form-control bg-light border-0 shadow-none rounded-3 py-2" placeholder="VD: 100000000" />
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Mô tả chi tiết</label>
                <textarea asp-for="Description" class="form-control bg-light border-0 shadow-none rounded-3 py-2" rows="4" placeholder="Mô tả các yêu cầu chức năng, phạm vi dự án..."></textarea>
            </div>
            <div class="col-12 text-end mt-4">
                <button type="submit" class="btn btn-success rounded-pill px-5 py-2 shadow-sm fw-bold">
                    <i class="fa-solid fa-save me-2"></i> Khởi tạo Dự án
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
