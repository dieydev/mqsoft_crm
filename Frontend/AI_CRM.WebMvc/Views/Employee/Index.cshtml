@model IEnumerable<AI_CRM.Domain.Entities.NhanVienPhuTrach>
@{
    ViewData["Title"] = "Quản lý Nhân viên";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-users-gear me-2 text-primary"></i>Quản lý Nhân sự Phụ trách</h3>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-plus me-2"></i> Thêm nhân viên
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 border-0" role="alert">
        <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3 border-0" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label text-muted fw-bold small text-uppercase">Tìm kiếm</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-search text-muted"></i></span>
                <input type="text" name="searchString" class="form-control border-start-0 bg-light" placeholder="Tên, Email, SĐT..." value="@ViewBag.SearchString">
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary px-4 w-100 rounded-3 shadow-sm fw-medium">Lọc dữ liệu</button>
        </div>
        <div class="col-md-4 text-end">
             @if (!string.IsNullOrEmpty(ViewBag.SearchString))
             {
                 <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-3"><i class="fa-solid fa-rotate-left me-1"></i> Xóa lọc</a>
             }
        </div>
    </form>
</div>

<div class="glass-card p-0 border-0 shadow-sm rounded-4 bg-white overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Họ và tên</th>
                    <th>Liên hệ</th>
                    <th>Phòng ban</th>
                    <th>Chức vụ</th>
                    <th>Tài khoản hệ thống</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4" width="120">Thao tác</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="https://ui-avatars.com/api/?name=@item.FullName&background=random" class="rounded-circle me-3" style="width: 40px; height: 40px;" />
                                    <div class="fw-bold text-dark">@item.FullName</div>
                                </div>
                            </td>
                            <td>
                                <div class="small"><i class="fa-solid fa-envelope me-1 text-muted"></i> @item.Email</div>
                                <div class="small"><i class="fa-solid fa-phone me-1 text-muted"></i> @item.Phone</div>
                            </td>
                            <td>@item.Department</td>
                            <td><span class="badge bg-secondary">@item.Position</span></td>
                            <td>
                                @if(item.NguoiDung != null)
                                {
                                    <span class="badge bg-info text-dark">@item.NguoiDung.Username</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Chưa cấp</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success-light text-success px-3 py-2 rounded-pill"><i class="fa-solid fa-circle-check me-1"></i> Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-light text-danger px-3 py-2 rounded-pill"><i class="fa-solid fa-lock me-1"></i> Đã khóa</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-3">
                                    <a asp-action="Edit" asp-route-id="@item.EmployeeId" class="btn btn-sm btn-outline-primary" title="Sửa">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Xóa" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.EmployeeId">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>

                                <!-- Delete Modal -->
                                <div class="modal fade" id="deleteModal-@item.EmployeeId" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content rounded-4 border-0 shadow">
                                            <div class="modal-header border-0 pb-0">
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body text-center pb-4">
                                                <div class="text-danger mb-3">
                                                    <i class="fa-regular fa-circle-xmark fa-4x"></i>
                                                </div>
                                                <h5 class="fw-bold mb-3 text-start text-center">Xác nhận xóa nhân viên</h5>
                                                <p class="text-muted mb-4">Bạn có chắc chắn muốn xóa nhân viên <strong class="text-dark">@item.FullName</strong>? Hành động này không thể hoàn tác.</p>
                                                <form asp-action="Delete" asp-route-id="@item.EmployeeId" method="post" class="d-flex gap-2 justify-content-center">
                                                    <button type="button" class="btn btn-light rounded-pill px-4 fw-medium" data-bs-dismiss="modal">Hủy bỏ</button>
                                                    <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm fw-medium">Đồng ý xóa</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="text-muted">
                                <i class="fa-solid fa-folder-open fa-3x mb-3 text-light"></i>
                                <h5 class="fw-bold">Không tìm thấy dữ liệu</h5>
                                <p>Chưa có nhân viên nào trong hệ thống hoặc không khớp với từ khóa tìm kiếm.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
