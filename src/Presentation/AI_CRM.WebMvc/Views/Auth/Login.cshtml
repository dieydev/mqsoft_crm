@model AI_CRM.WebMvc.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - MQSoft CRM</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --bg-light: #f8fafc;
            --text-dark: #0f172a;
            --text-muted: #64748b;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Outfit', sans-serif;
        }

        .auth-container {
            background: #fff;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
            min-height: 700px;
        }

        .auth-left {
            background: linear-gradient(135deg, rgba(79, 70, 229, 0.8), rgba(236, 72, 153, 0.8)), 
                        url('https://images.pexels.com/photos/3183150/pexels-photo-3183150.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2') center/cover no-repeat;
            position: relative;
            padding: 4rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            color: white;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 16px;
            padding: 2rem;
        }

        .auth-right {
            padding: 4rem 5rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-control {
            padding: 0.875rem 1.25rem;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            background-color: #f8fafc;
            font-size: 0.95rem;
            transition: all 0.3s;
        }

        .form-control:focus {
            background-color: #fff;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        .btn-primary {
            background-color: var(--primary);
            border-color: var(--primary);
            padding: 0.875rem 1.5rem;
            border-radius: 12px;
            font-weight: 600;
            letter-spacing: 0.3px;
            transition: all 0.3s;
        }

        .btn-primary:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(79, 70, 229, 0.2);
        }

        .btn-google {
            background-color: #fff;
            color: var(--text-dark);
            border: 1px solid #e2e8f0;
            padding: 0.875rem 1.5rem;
            border-radius: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s;
        }

        .btn-google:hover {
            background-color: #f8fafc;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
        }

        .btn-google img {
            width: 20px;
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: var(--text-muted);
            margin: 2rem 0;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #e2e8f0;
        }

        .divider::before { margin-right: 1em; }
        .divider::after { margin-left: 1em; }

        .auth-logo {
            max-height: 50px;
            margin-bottom: 2rem;
        }

        @@media (max-width: 991.98px) {
            .auth-left { display: none !important; }
            .auth-right { padding: 3rem 2rem; }
            .auth-container { min-height: auto; }
        }
    </style>
</head>
<body>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-xl-10 col-lg-12">
                <div class="auth-container d-flex flex-column flex-lg-row">
                    
                    <!-- Left Side: Banner -->
                    <div class="col-lg-5 auth-left d-none d-lg-flex">
                        <div>
                            <img src="~/images/logo.png" alt="MQSoft Logo" class="mb-4" style="filter: brightness(0) invert(1); max-height: 60px;" />
                        </div>
                        
                        <div class="glass-panel mb-5">
                            <h3 class="fw-bold mb-3">Giải pháp Quản trị Thông minh</h3>
                            <p class="mb-0 lh-lg" style="opacity: 0.9;">
                                Hệ sinh thái phần mềm tích hợp AI, tối ưu hóa quy trình làm việc, quản lý khách hàng và dự án toàn diện dành riêng cho doanh nghiệp của bạn.
                            </p>
                        </div>

                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex">
                                <img src="https://ui-avatars.com/api/?name=A&background=random" class="rounded-circle border border-2 border-white" style="width: 40px; margin-right: -15px;" alt="User">
                                <img src="https://ui-avatars.com/api/?name=B&background=random" class="rounded-circle border border-2 border-white" style="width: 40px; margin-right: -15px;" alt="User">
                                <img src="https://ui-avatars.com/api/?name=C&background=random" class="rounded-circle border border-2 border-white" style="width: 40px;" alt="User">
                            </div>
                            <div class="small fw-medium">
                                <i class="fa-solid fa-star text-warning"></i> 5.0 (Hơn 1,000+ doanh nghiệp)
                            </div>
                        </div>
                    </div>

                    <!-- Right Side: Form -->
                    <div class="col-12 col-lg-7 auth-right">
                        <div class="text-center text-lg-start mb-4">
                            <img src="~/images/logo.png" alt="MQSoft Logo" class="auth-logo d-lg-none mx-auto" />
                            <h2 class="fw-bold text-dark mb-2">Chào mừng trở lại! 👋</h2>
                            <p class="text-muted">Vui lòng đăng nhập để truy cập vào hệ thống.</p>
                        </div>

                        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 small fw-medium border-0 rounded-3"></div>

                            @if (TempData["ErrorMessage"] != null)
                            {
                                <div class="alert alert-danger py-2 px-3 small fw-medium border-0 rounded-3">
                                    <i class="fa-solid fa-triangle-exclamation me-1"></i> @TempData["ErrorMessage"]
                                </div>
                            }

                            <div class="mb-4">
                                <label asp-for="Username" class="form-label text-dark fw-semibold small">Tên đăng nhập / Email</label>
                                <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập của bạn..." />
                                <span asp-validation-for="Username" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <label asp-for="Password" class="form-label text-dark fw-semibold small mb-0">Mật khẩu</label>
                                    <a href="#" class="text-primary text-decoration-none small fw-semibold">Quên mật khẩu?</a>
                                </div>
                                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="form-check mb-4">
                                <input asp-for="RememberMe" class="form-check-input shadow-none" type="checkbox" id="rememberMe" />
                                <label class="form-check-label text-muted small fw-medium" for="rememberMe">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 mb-3">
                                Đăng Nhập
                            </button>
                            
                        </form>

                        <div class="divider">HOẶC TIẾP TỤC VỚI</div>

                        <form asp-action="GoogleLogin" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                            <button type="submit" class="btn btn-google w-100 mb-4">
                                <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google">
                                Đăng nhập bằng Google
                            </button>
                        </form>

                        <p class="text-center text-muted small fw-medium mb-0 mt-3">
                            Chưa có tài khoản? <span class="text-primary fw-bold" style="cursor: help;" title="Vui lòng liên hệ Quản trị viên để được cấp tài khoản">Liên hệ Admin</span>
                        </p>
                    </div>

                </div>
            </div>
            
            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small fw-medium hover-primary">
                    <i class="fa-solid fa-arrow-left me-1"></i> Quay lại trang chủ
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
