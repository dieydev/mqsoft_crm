@model IEnumerable<AI_CRM.Domain.Entities.HopDong>
@{
    ViewData["Title"] = "Quản lý hợp đồng";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-4" role="alert">
        <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-file-contract me-2 text-primary"></i>Quản lý Hợp đồng</h3>
    
    <div class="d-flex flex-column flex-md-row gap-2">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control rounded-pill px-3 shadow-sm border-0" placeholder="Tìm hợp đồng, KH...">
            <select name="statusId" class="form-select rounded-pill px-3 shadow-sm border-0" asp-items="ViewBag.StatusList">
                <option value="">-- Tất cả trạng thái --</option>
            </select>
            <button type="submit" class="btn btn-secondary rounded-pill px-3 shadow-sm"><i class="fa-solid fa-search"></i></button>
            <a asp-action="Index" class="btn btn-light rounded-pill px-3 shadow-sm text-muted"><i class="fa-solid fa-rotate-right"></i></a>
        </form>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus"></i> Tạo hợp đồng
        </a>
    </div>
</div>

<div class="glass-card overflow-hidden border-0 shadow-sm rounded-4" style="background: #fff;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" style="border-collapse: separate; border-spacing: 0;">
            <thead class="bg-light text-muted" style="font-size: 0.85rem; text-transform: uppercase;">
                <tr>
                    <th class="ps-4 py-3 fw-bold border-bottom-0">Số hợp đồng</th>
                    <th class="py-3 fw-bold border-bottom-0">Khách hàng</th>
                    <th class="py-3 fw-bold border-bottom-0">Tên hợp đồng</th>
                    <th class="py-3 fw-bold border-bottom-0">Giá trị</th>
                    <th class="py-3 fw-bold border-bottom-0">Ngày ký</th>
                    <th class="py-3 fw-bold border-bottom-0">Hết hạn</th>
                    <th class="py-3 fw-bold border-bottom-0">Trạng thái</th>
                    <th class="text-end pe-4 py-3 fw-bold border-bottom-0">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-bold text-primary">@item.ContractNumber</td>
                            <td class="py-3 fw-medium">@(item.KhachHang?.CompanyName ?? "N/A")</td>
                            <td class="py-3 text-truncate" style="max-width: 150px;" title="@item.ContractName">@item.ContractName</td>
                            <td class="py-3 fw-bold text-success">@(item.ContractValue?.ToString("N0") ?? "0") VNĐ</td>
                            <td class="py-3">@(item.SignDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="py-3">
                                @(item.ExpireDate?.ToString("dd/MM/yyyy") ?? "-")
                                @if (item.ExpireDate.HasValue && item.ExpireDate.Value.Subtract(DateTime.Now).TotalDays <= 30 && item.ExpireDate.Value.Subtract(DateTime.Now).TotalDays > 0)
                                {
                                    <span class="badge bg-warning text-dark ms-2"><i class="fa-solid fa-clock"></i> Sắp hết hạn</span>
                                }
                                else if (item.ExpireDate.HasValue && item.ExpireDate.Value < DateTime.Now)
                                {
                                    <span class="badge bg-danger ms-2"><i class="fa-solid fa-exclamation-circle"></i> Đã hết hạn</span>
                                }
                            </td>
                            <td class="py-3">
                                @{
                                    var statusClass = item.TrangThaiHopDong?.StatusName switch
                                    {
                                        "Đang hiệu lực" => "bg-success text-white",
                                        "Mới tạo" => "bg-info text-white",
                                        "Đã thanh lý" => "bg-secondary text-white",
                                        "Hủy bỏ" => "bg-danger text-white",
                                        _ => "bg-light text-dark"
                                    };
                                }
                                <span class="badge @statusClass fw-normal border border-opacity-10">@(item.TrangThaiHopDong?.StatusName ?? "Không rõ")</span>
                            </td>
                            <td class="text-end pe-4 py-3">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (!string.IsNullOrEmpty(item.FilePath))
                                    {
                                        <a href="@item.FilePath" target="_blank" class="btn btn-sm btn-light text-primary shadow-sm rounded-3 px-2 py-1" title="Xem file"><i class="fa-solid fa-file-pdf"></i></a>
                                    }
                                    <a asp-action="Edit" asp-route-id="@item.ContractId" class="btn btn-sm btn-light text-warning shadow-sm rounded-3 px-2 py-1" title="Sửa"><i class="fa-solid fa-pen"></i></a>
                                    
                                    <form asp-action="Delete" asp-route-id="@item.ContractId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa hợp đồng này không?');">
                                        <button type="submit" class="btn btn-sm btn-light text-danger shadow-sm rounded-3 px-2 py-1" title="Xóa"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-folder-open fs-1 mb-3 opacity-50"></i>
                            <p class="mb-0 fs-5">Chưa có dữ liệu hợp đồng. Hãy tạo mới!</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
