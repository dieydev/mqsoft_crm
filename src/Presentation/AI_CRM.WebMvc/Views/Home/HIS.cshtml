@{
    ViewData["Title"] = "Quản lý bệnh viện (HIS)";
    Layout = "_UserLayout";
}

<div class="container py-5 mt-5">
    <!-- Header Section -->
    <div class="text-center mb-5 pb-4" data-aos="fade-up">
        <h2 class="fw-bold text-uppercase mb-4" style="color: #17538a; font-family: var(--font-heading); font-size: 2.2rem;">Hệ Thống Quản Lý Bệnh Viện (HIS)</h2>
        <div class="mx-auto" style="max-width: 950px;">
            <p class="fs-6 text-dark mb-3" style="line-height: 1.8; text-align: center;">
                Phần mềm Quản lý bệnh viện (HIS) của MQ Solutions là giải pháp toàn diện giúp tự động hóa toàn bộ quy trình khám chữa bệnh, tối ưu hóa các thủ tục hành chính, từ đăng ký khám bệnh đến thanh toán viện phí.
            </p>
        </div>
    </div>

    <!-- Content Section -->
    <div class="row align-items-center g-5">
        <div class="col-lg-7" data-aos="fade-right" data-aos-delay="100">
            <div class="d-flex mb-4 pb-3">
                <div class="flex-shrink-0 me-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; border: 2px solid #17538a; background-color: #f3f0ff;">
                        <i class="fa-solid fa-users fa-2x" style="color: #17538a;"></i>
                    </div>
                </div>
                <div>
                    <h4 class="fw-bold mb-2" style="color: #17538a;">Quản lý bệnh nhân tập trung</h4>
                    <p class="text-muted mb-0" style="line-height: 1.7; text-align: justify;">
                        Số hóa thông tin bệnh nhân, quản lý hồ sơ khám chữa bệnh một cách đồng bộ và bảo mật cao. Truy xuất lịch sử khám bệnh nhanh chóng, nâng cao trải nghiệm của người bệnh.
                    </p>
                </div>
            </div>

            <div class="d-flex mb-4 pb-3">
                <div class="flex-shrink-0 me-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; border: 2px solid #17538a; background-color: #e3f2fd;">
                        <i class="fa-solid fa-money-check-dollar fa-2x" style="color: #17538a;"></i>
                    </div>
                </div>
                <div>
                    <h4 class="fw-bold mb-2" style="color: #17538a;">Thanh toán & Bảo hiểm y tế</h4>
                    <p class="text-muted mb-0" style="line-height: 1.7; text-align: justify;">
                        Tích hợp trực tiếp với cổng giám định BHYT, tự động áp mã và tính toán chi phí chính xác. Hỗ trợ đa dạng phương thức thanh toán không tiền mặt, giảm thiểu sai sót.
                    </p>
                </div>
            </div>

            <div class="d-flex">
                <div class="flex-shrink-0 me-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; border: 2px solid #17538a; background-color: #e0f7fa;">
                        <i class="fa-solid fa-pills fa-2x" style="color: #17538a;"></i>
                    </div>
                </div>
                <div>
                    <h4 class="fw-bold mb-2" style="color: #17538a;">Kiểm kê vật tư & Dược phẩm</h4>
                    <p class="text-muted mb-0" style="line-height: 1.7; text-align: justify;">
                        Theo dõi thời gian thực quá trình nhập, xuất, tồn kho thuốc và vật tư y tế. Cảnh báo thuốc cận date hoặc số lượng tối thiểu, ngăn ngừa thất thoát triệt để.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-5 text-center" data-aos="fade-left" data-aos-delay="200">
            <img src="/images/Dichvu/services-socialmediamarketing-alt-colors-optimized.png" alt="HIS" class="img-fluid rounded-4 shadow-lg border border-4 border-white" style="object-fit: contain; background-color:#17538a; padding: 2rem;">
        </div>
    </div>
</div>
