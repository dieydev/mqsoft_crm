@model AI_CRM.Domain.Entities.TienDoDuAn
@{
    ViewData["Title"] = "Sửa báo cáo tiến độ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-pen me-2 text-warning"></i>Sửa Báo cáo tiến độ</h3>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
    </a>
</div>

<div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="ProgressId" />
        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Dự án <span class="text-danger">*</span></label>
                <select asp-for="ProjectId" class="form-select bg-light border-0 shadow-none rounded-3 py-2" asp-items="ViewBag.ProjectId" required>
                    <option value="">-- Chọn dự án --</option>
                </select>
                <span asp-validation-for="ProjectId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Người báo cáo (Nhân viên)</label>
                <select asp-for="UpdatedBy" class="form-select bg-light border-0 shadow-none rounded-3 py-2" asp-items="ViewBag.UpdatedBy">
                    <option value="">-- Chọn nhân viên --</option>
                </select>
                <span asp-validation-for="UpdatedBy" class="text-danger small"></span>
            </div>
            
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Mức độ hoàn thành (%) <span class="text-danger">*</span></label>
                <div class="d-flex align-items-center gap-3">
                    <input type="range" class="form-range flex-grow-1" min="0" max="100" asp-for="ProgressPercent" oninput="document.getElementById('percentOutput').innerText = this.value + '%'">
                    <span id="percentOutput" class="fw-bold text-success fs-5 w-25 text-end">@(Model?.ProgressPercent ?? 0)%</span>
                </div>
                <span asp-validation-for="ProgressPercent" class="text-danger small"></span>
            </div>

            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Nội dung / Ghi chú <span class="text-danger">*</span></label>
                <textarea asp-for="Note" class="form-control bg-light border-0 shadow-none rounded-3 py-2" rows="4" required></textarea>
                <span asp-validation-for="Note" class="text-danger small"></span>
            </div>
            
            <div class="col-12 text-end mt-4">
                <button type="submit" class="btn btn-warning text-dark rounded-pill px-5 py-2 shadow-sm fw-bold">
                    <i class="fa-solid fa-save me-2"></i> Cập nhật Báo cáo
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
