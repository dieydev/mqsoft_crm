@{
    ViewData["Title"] = "Về Chúng Tôi";
    Layout = "_UserLayout";
}

<div class="container py-5 mt-5">
    <!-- Header Section -->
    <div class="text-center mb-5 pb-4" data-aos="fade-up">
        <h2 class="fw-bold text-uppercase mb-4" style="color: #2b3990; font-family: var(--font-heading); font-size: 2.2rem;">Vì Sao Nên Chọn Chúng Tôi?</h2>
        <div class="mx-auto" style="max-width: 950px;">
            <p class="fs-6 text-dark mb-3" style="line-height: 1.8; text-align: center;">
                Công ty Cổ Phần MQ Solutions là một công ty chuyên tư vấn và cung cấp phần mềm có bản quyền cũng như các giải pháp cho các đơn vị trong lĩnh vực y tế.
            </p>
            <p class="fs-6 text-dark" style="line-height: 1.8; text-align: center;">
                Công ty đang phát triển bởi nhiều kỹ sư, tốt nghiệp từ các trường đại học nổi tiếng ở Việt Nam. Hướng của MQ Solutions là nghiên cứu và ứng dụng công nghệ mới trong sản xuất, tạo ra sản phẩm, giải pháp nhằm đáp ứng các yêu cầu hạn chế của các bệnh viện, đưa khoa học công nghệ vào mô hình quản lý bệnh viện nhằm góp phần nâng cao chất lượng phục vụ sức khỏe cộng đồng.
            </p>
        </div>
    </div>

    <!-- Content Section -->
    <div class="row align-items-center g-5">
        <!-- Left Column: Features -->
        <div class="col-lg-7" data-aos="fade-right" data-aos-delay="100">
            <!-- Feature 1 -->
            <div class="d-flex mb-4 pb-3">
                <div class="flex-shrink-0 me-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; border: 2px solid #6c5ce7; background-color: #f3f0ff;">
                        <i class="fa-solid fa-mobile-screen-button fa-2x" style="color: #6c5ce7;"></i>
                    </div>
                </div>
                <div>
                    <h4 class="fw-bold mb-2" style="color: #2b3990;">Hệ Thống Đạt Chất Lượng</h4>
                    <p class="text-muted mb-0" style="line-height: 1.7; text-align: justify;">
                        Hệ thống quản lý chất lượng của MQ Soft được tổ chức phù hợp với các yêu cầu, bộ tiêu chuẩn TCVN ISO 9001:2008, ISMS, CMMi3 và phù hợp với tính chất, đặc điểm của các sản phẩm/dịch vụ trong lĩnh vực Công nghệ thông tin cũng như phù hợp với yêu cầu khách hàng của Công ty.
                    </p>
                </div>
            </div>

            <!-- Feature 2 -->
            <div class="d-flex mb-4 pb-3">
                <div class="flex-shrink-0 me-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; border: 2px solid #0984e3; background-color: #e3f2fd;">
                        <i class="fa-solid fa-file-contract fa-2x" style="color: #0984e3;"></i>
                    </div>
                </div>
                <div>
                    <h4 class="fw-bold mb-2" style="color: #2b3990;">Chính Sách, Quyền Lợi</h4>
                    <p class="text-muted mb-0" style="line-height: 1.7; text-align: justify;">
                        MQSoft đã xây dựng một chính sách chất lượng nhất quán với những định hướng phát triển chung của công ty, đáp ứng các yêu cầu cải tiến thường xuyên của hệ thống, làm cơ sở cho việc thiết lập và xem xét các mục tiêu chất lượng. Hơn nữa, chính sách MQSoft luôn chú trọng hướng tới khách hàng, đảm bảo đem tới khách hàng những quyền lợi tốt nhất.
                    </p>
                </div>
            </div>

            <!-- Feature 3 -->
            <div class="d-flex">
                <div class="flex-shrink-0 me-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; border: 2px solid #00cec9; background-color: #e0f7fa;">
                        <i class="fa-solid fa-headset fa-2x" style="color: #00cec9;"></i>
                    </div>
                </div>
                <div>
                    <h4 class="fw-bold mb-2" style="color: #2b3990;">Hỗ trợ, Quản lý sản phẩm</h4>
                    <p class="text-muted mb-0" style="line-height: 1.7; text-align: justify;">
                        Thiết lập, đảm bảo sự toàn vẹn và an toàn của sản phẩm dự án trong suốt chu trình hoạt động của dự án phần mềm.<br><br>
                        Cung cấp công cụ và hỗ trợ cán bộ quản lý theo dõi được quy trình đang áp dụng tại dự án phần mềm và của sản phẩm phần mềm đang xây dựng. Xem xét (review) và đánh giá (audit) sản phẩm phần mềm và các hoạt động sản xuất để đảm bảo rằng chúng tuân thủ với các thủ tục và các tiêu chuẩn được quy định.
                    </p>
                </div>
            </div>
        </div>

        <!-- Right Column: Image -->
        <div class="col-lg-5 text-center" data-aos="fade-left" data-aos-delay="200">
            <!-- Using a high quality tech illustration/photo placeholder since we don't have the exact illustration -->
            <img src="https://images.pexels.com/photos/1181244/pexels-photo-1181244.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Tại sao chọn MQ Solutions" class="img-fluid rounded-4 shadow-lg border border-4 border-white" style="object-fit: cover; max-height: 550px;">
        </div>
    </div>
</div>
