@model AI_CRM.Domain.Entities.HopDong
@{
    ViewData["Title"] = "Chi tiết Hợp đồng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-file-contract me-2 text-primary"></i>Chi tiết Hợp đồng</h3>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn btn-warning shadow-sm fw-medium me-2">
            <i class="fa-solid fa-pen"></i> Chỉnh sửa
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
            <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="glass-card p-4 border-0 shadow-sm rounded-4 h-100">
            <h5 class="fw-bold text-primary mb-4 border-bottom pb-2">Thông tin chung</h5>
            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">Số hợp đồng:</div>
                <div class="col-sm-8 fw-bold text-dark">@Model.ContractNumber</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">Tên hợp đồng:</div>
                <div class="col-sm-8 text-dark">@Model.ContractName</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">Khách hàng:</div>
                <div class="col-sm-8">
                    <a asp-controller="Customer" asp-action="Details" asp-route-id="@Model.CustomerId" class="fw-bold text-primary text-decoration-none">
                        @(Model.KhachHang?.CompanyName ?? "N/A")
                    </a>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">Giá trị hợp đồng:</div>
                <div class="col-sm-8 fw-bold text-success">@(Model.ContractValue?.ToString("N0") ?? "0") VNĐ</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">Ngày ký:</div>
                <div class="col-sm-8">@(Model.SignDate?.ToString("dd/MM/yyyy") ?? "-")</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">Ngày hết hạn:</div>
                <div class="col-sm-8">
                    @(Model.ExpireDate?.ToString("dd/MM/yyyy") ?? "-")
                    @if (Model.ExpireDate.HasValue && Model.ExpireDate.Value.Subtract(DateTime.Now).TotalDays <= 30 && Model.ExpireDate.Value.Subtract(DateTime.Now).TotalDays > 0)
                    {
                        <span class="badge bg-warning text-dark ms-2"><i class="fa-solid fa-clock"></i> Sắp hết hạn</span>
                    }
                    else if (Model.ExpireDate.HasValue && Model.ExpireDate.Value < DateTime.Now)
                    {
                        <span class="badge bg-danger ms-2"><i class="fa-solid fa-exclamation-circle"></i> Đã hết hạn</span>
                    }
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">Trạng thái:</div>
                <div class="col-sm-8">
                    @{
                        var statusClass = Model.TrangThaiHopDong?.StatusName switch
                        {
                            "Đang hiệu lực" => "bg-success text-white",
                            "Mới tạo" => "bg-info text-white",
                            "Đã thanh lý" => "bg-secondary text-white",
                            "Hủy bỏ" => "bg-danger text-white",
                            _ => "bg-light text-dark"
                        };
                    }
                    <span class="badge @statusClass fw-normal border border-opacity-10 px-2 py-1">@(Model.TrangThaiHopDong?.StatusName ?? "Không rõ")</span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 text-muted fw-medium">File đính kèm:</div>
                <div class="col-sm-8">
                    @if (!string.IsNullOrEmpty(Model.FilePath))
                    {
                        <a href="@Model.FilePath" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill">
                            <i class="fa-solid fa-file-pdf"></i> Xem hợp đồng PDF
                        </a>
                    }
                    else
                    {
                        <span class="text-muted fst-italic">Không có file đính kèm</span>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="glass-card p-4 border-0 shadow-sm rounded-4 h-100 bg-light">
            <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">Dự án liên kết</h5>
            @if (Model.DuAns != null && Model.DuAns.Any())
            {
                <div class="list-group list-group-flush bg-transparent">
                    @foreach (var duan in Model.DuAns.Where(d => !d.IsDeleted))
                    {
                        <a asp-controller="Project" asp-action="Details" asp-route-id="@duan.ProjectId" class="list-group-item list-group-item-action bg-transparent border-bottom-0 mb-2 rounded-3 shadow-sm" style="background-color: var(--surface-color) !important;">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1 fw-bold text-primary text-truncate">@duan.ProjectName</h6>
                            </div>
                            <small class="text-muted">Ngân sách: @(duan.Budget?.ToString("N0") ?? "0") VNĐ</small>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fa-solid fa-diagram-project fs-1 text-muted opacity-25 mb-3"></i>
                    <p class="text-muted mb-0">Chưa có dự án nào liên kết với hợp đồng này.</p>
                </div>
            }
        </div>
    </div>
</div>
