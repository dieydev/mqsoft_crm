@{
    ViewData["Title"] = "Cài đặt hệ thống";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold mb-0">Cài đặt</h2>
            <p class="text-muted">Tùy chỉnh trải nghiệm của bạn trên hệ thống CRM</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0"><i class="fa-solid fa-palette text-primary me-2"></i> Giao diện</h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="fw-bold mb-1">Chế độ tối (Dark Mode)</h6>
                            <p class="text-muted small mb-0">Chuyển đổi giao diện sang nền tối để dịu mắt hơn vào ban đêm.</p>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input fs-4" type="checkbox" role="switch" id="darkModeSwitch">
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0"><i class="fa-solid fa-bell text-warning me-2"></i> Thông báo</h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="fw-bold mb-1">Thông báo qua Email</h6>
                            <p class="text-muted small mb-0">Nhận email khi có tiến độ dự án hoặc cập nhật từ khách hàng.</p>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input fs-4" type="checkbox" role="switch" checked disabled>
                        </div>
                    </div>
                    <hr class="text-muted opacity-25">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="fw-bold mb-1">Thông báo hệ thống (Push Notifications)</h6>
                            <p class="text-muted small mb-0">Nhận cảnh báo trực tiếp trên trình duyệt.</p>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input fs-4" type="checkbox" role="switch" checked disabled>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0"><i class="fa-solid fa-language text-success me-2"></i> Ngôn ngữ & Khu vực</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold">Ngôn ngữ hiển thị</label>
                            <select class="form-select" disabled>
                                <option value="vi" selected>Tiếng Việt</option>
                                <option value="en">English (US)</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold">Múi giờ</label>
                            <select class="form-select" disabled>
                                <option value="GMT+7" selected>(UTC+07:00) Bangkok, Hanoi, Jakarta</option>
                            </select>
                        </div>
                    </div>
                    <div class="alert alert-light border small text-muted mt-2 mb-0">
                        <i class="fa-solid fa-circle-info me-1"></i> Các cài đặt hệ thống hiện được quản lý bởi Quản trị viên (Admin).
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const darkModeSwitch = document.getElementById('darkModeSwitch');
            const currentTheme = document.documentElement.getAttribute('data-bs-theme');
            
            if (currentTheme === 'dark') {
                darkModeSwitch.checked = true;
            }

            darkModeSwitch.addEventListener('change', function() {
                // Click the existing theme toggle button from _Layout.cshtml
                const themeBtn = document.getElementById('themeToggleBtn');
                if (themeBtn) {
                    themeBtn.click();
                }
            });
        });
    </script>
}
