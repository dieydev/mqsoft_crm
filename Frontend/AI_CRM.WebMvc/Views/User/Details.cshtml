@model AI_CRM.Domain.Entities.NguoiDung
@{
    ViewData["Title"] = "Chi tiết tài khoản";
    var roleName = Model.VaiTro?.RoleName ?? "Chưa phân quyền";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-3 py-2 me-3">
        <i class="fa-solid fa-arrow-left"></i>
    </a>
    <div>
        <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-user-circle me-2 text-primary"></i>Chi tiết tài khoản</h3>
        <p class="text-muted mb-0 small">Xem thông tin chi tiết tài khoản: <strong>@Model.Username</strong></p>
    </div>
</div>

<div class="row">
    <!-- Thông tin chính -->
    <div class="col-lg-4 mb-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body text-center p-4">
                <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(Model.Username))&background=4f46e5&color=fff&size=120&bold=true"
                     class="rounded-circle mb-3 shadow" style="width: 120px; height: 120px; border: 4px solid #e2e8f0;" />

                <h4 class="fw-bold mb-1 text-dark">@Model.Username</h4>
                <p class="text-muted mb-3">
                    @{
                        var roleBadgeClass = roleName switch
                        {
                            "Admin" => "bg-danger",
                            "Manager" => "bg-warning text-dark",
                            "Employee" => "bg-primary",
                            _ => "bg-secondary"
                        };
                        var roleIcon = roleName switch
                        {
                            "Admin" => "fa-crown",
                            "Manager" => "fa-star",
                            _ => "fa-user"
                        };
                    }
                    <span class="badge @roleBadgeClass px-3 py-2 rounded-pill fs-6">
                        <i class="fa-solid @roleIcon me-1"></i> @roleName
                    </span>
                </p>

                @if (Model.IsActive)
                {
                    <div class="d-inline-flex align-items-center gap-2 bg-success-light text-success px-3 py-2 rounded-pill">
                        <div class="rounded-circle bg-success" style="width: 8px; height: 8px; animation: pulse 2s infinite;"></div>
                        <span class="fw-medium small">Đang hoạt động</span>
                    </div>
                }
                else
                {
                    <div class="d-inline-flex align-items-center gap-2 bg-danger-light text-danger px-3 py-2 rounded-pill">
                        <i class="fa-solid fa-ban"></i>
                        <span class="fw-medium small">Đã khóa</span>
                    </div>
                }

                <hr class="text-muted my-4">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted small"><i class="fa-solid fa-hashtag me-1"></i> Mã tài khoản</span>
                    <span class="fw-bold text-dark">#@Model.UserId</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted small"><i class="fa-regular fa-calendar me-1"></i> Ngày tạo</span>
                    <span class="fw-medium text-dark small">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small"><i class="fa-solid fa-clock-rotate-left me-1"></i> Thời gian sử dụng</span>
                    <span class="fw-medium text-dark small">@((DateTime.Now - Model.CreatedDate).Days) ngày</span>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <hr class="text-muted my-4">
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-primary rounded-pill">
                            <i class="fa-solid fa-pen-to-square me-1"></i> Sửa thông tin
                        </a>
                        <form asp-action="ToggleStatus" asp-route-id="@Model.UserId" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn @(Model.IsActive ? "btn-outline-danger" : "btn-outline-success") rounded-pill w-100"
                                    onclick="return confirm('@(Model.IsActive ? "Bạn có chắc muốn KHÓA tài khoản này?" : "Bạn có chắc muốn MỞ KHÓA tài khoản này?")')">
                                <i class="fa-solid @(Model.IsActive ? "fa-lock" : "fa-lock-open") me-1"></i>
                                @(Model.IsActive ? "Khóa tài khoản" : "Mở khóa tài khoản")
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <!-- Thông tin vai trò -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold mb-0">
                    <i class="fa-solid fa-shield-halved text-warning me-2"></i> Thông tin vai trò & quyền hạn
                </h5>
            </div>
            <div class="card-body p-4">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small fw-bold">Vai trò hiện tại</label>
                        <div class="form-control bg-light rounded-3 py-2">
                            <i class="fa-solid @roleIcon text-primary me-1"></i> @roleName
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small fw-bold">Mô tả vai trò</label>
                        <div class="form-control bg-light rounded-3 py-2">
                            @(Model.VaiTro?.Description ?? "Không có mô tả")
                        </div>
                    </div>
                </div>

                <!-- Bảng quyền hạn -->
                <div class="mt-3">
                    <label class="form-label text-muted small fw-bold mb-2">Quyền hạn trên hệ thống</label>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered rounded-3 overflow-hidden mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="fw-bold small py-2">Module</th>
                                    <th class="fw-bold small text-center py-2">Xem</th>
                                    <th class="fw-bold small text-center py-2">Thêm</th>
                                    <th class="fw-bold small text-center py-2">Sửa</th>
                                    <th class="fw-bold small text-center py-2">Xóa</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var modules = new[] { "Khách hàng", "Hợp đồng", "Dự án", "Tài liệu", "Người dùng", "Báo cáo" };
                                    foreach (var module in modules)
                                    {
                                        var isUserModule = module == "Người dùng" || module == "Báo cáo";
                                        <tr>
                                            <td class="small fw-medium">@module</td>
                                            <td class="text-center">
                                                <i class="fa-solid fa-check-circle text-success"></i>
                                            </td>
                                            <td class="text-center">
                                                @if (roleName == "Admin" || (!isUserModule && roleName != "User"))
                                                {
                                                    <i class="fa-solid fa-check-circle text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa-solid fa-times-circle text-danger opacity-50"></i>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (roleName == "Admin" || (!isUserModule && roleName != "User"))
                                                {
                                                    <i class="fa-solid fa-check-circle text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa-solid fa-times-circle text-danger opacity-50"></i>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (roleName == "Admin")
                                                {
                                                    <i class="fa-solid fa-check-circle text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa-solid fa-times-circle text-danger opacity-50"></i>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nhân viên liên kết -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold mb-0">
                    <i class="fa-solid fa-id-badge text-primary me-2"></i> Nhân viên liên kết
                </h5>
            </div>
            <div class="card-body p-4">
                @if (Model.NhanVienPhuTrachs != null && Model.NhanVienPhuTrachs.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="fw-bold small py-2">Họ tên</th>
                                    <th class="fw-bold small py-2">Email</th>
                                    <th class="fw-bold small py-2">Bộ phận</th>
                                    <th class="fw-bold small py-2">Chức vụ</th>
                                    <th class="fw-bold small py-2">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var nv in Model.NhanVienPhuTrachs)
                                {
                                    <tr>
                                        <td class="fw-medium">@nv.FullName</td>
                                        <td class="text-muted small">@nv.Email</td>
                                        <td class="small">@(nv.Department ?? "N/A")</td>
                                        <td class="small">@(nv.Position ?? "N/A")</td>
                                        <td>
                                            @if (nv.IsActive)
                                            {
                                                <span class="badge bg-success-light text-success rounded-pill">Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-light text-danger rounded-pill">Ngừng</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-user-slash fs-2 opacity-50 mb-2"></i>
                        <p class="mb-0 small">Tài khoản này chưa liên kết với hồ sơ nhân viên nào.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Nhật ký hoạt động -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold mb-0">
                    <i class="fa-solid fa-clock-rotate-left text-success me-2"></i> Nhật ký hoạt động gần đây
                </h5>
            </div>
            <div class="card-body p-4">
                @if (Model.NhatKyHeThongs != null && Model.NhatKyHeThongs.Any())
                {
                    <div class="timeline-list">
                        @foreach (var log in Model.NhatKyHeThongs)
                        {
                            <div class="d-flex align-items-start gap-3 mb-3 pb-3 border-bottom">
                                <div class="stat-icon bg-primary-light flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.85rem;">
                                    <i class="fa-solid fa-clock"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="fw-bold small mb-0 text-dark">@log.Action</h6>
                                            <p class="text-muted small mb-0">@(log.Details ?? "Không có chi tiết") · Bảng: @(log.TableName ?? "N/A")</p>
                                        </div>
                                        <small class="text-muted flex-shrink-0">@log.Timestamp.ToString("dd/MM HH:mm")</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-inbox fs-2 opacity-50 mb-2"></i>
                        <p class="mb-0 small">Chưa có nhật ký hoạt động nào.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }
</style>
