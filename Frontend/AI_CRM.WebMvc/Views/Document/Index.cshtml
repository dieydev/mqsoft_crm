@model IEnumerable<AI_CRM.Domain.Entities.TaiLieuNoiBo>
@{
    ViewData["Title"] = "Tài liệu nội bộ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-folder-open me-2 text-primary"></i>Quản lý Tài liệu nội bộ</h3>
    <a href="#" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-medium d-flex align-items-center gap-2">
        <i class="fa-solid fa-upload"></i> Upload Tài liệu
    </a>
</div>

<div class="glass-card p-4 border-0 shadow-sm rounded-4" style="background: #fff;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted" style="font-size: 0.85rem; text-transform: uppercase;">
                <tr>
                    <th class="ps-4 py-3 fw-bold border-bottom-0">Tên tài liệu</th>
                    <th class="py-3 fw-bold border-bottom-0">Nhóm</th>
                    <th class="py-3 fw-bold border-bottom-0">Người upload</th>
                    <th class="py-3 fw-bold border-bottom-0">Ngày tạo</th>
                    <th class="py-3 fw-bold border-bottom-0 text-center">AI Data</th>
                    <th class="text-end pe-4 py-3 fw-bold border-bottom-0">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-bold text-dark">
                                <i class="fa-solid fa-file-pdf text-danger me-2"></i> @item.Title
                            </td>
                            <td class="py-3">
                                <span class="badge bg-secondary-light text-secondary">@(item.NhomTaiLieu?.CategoryName ?? "Chung")</span>
                            </td>
                            <td class="py-3">@(item.NhanVienPhuTrach?.FullName ?? "System")</td>
                            <td class="py-3 text-muted">@item.UploadDate.ToString("dd/MM/yyyy")</td>
                            <td class="py-3 text-center">
                                @if (item.IsProcessedForAI)
                                {
                                    <i class="fa-solid fa-check-circle text-success fs-5" title="Đã đưa vào Knowledge Base"></i>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-primary rounded-pill py-0" style="font-size: 0.75rem;"><i class="fa-solid fa-brain me-1"></i>Train AI</button>
                                }
                            </td>
                            <td class="text-end pe-4 py-3">
                                <button class="btn btn-sm btn-light text-primary shadow-sm rounded-3 px-2 py-1" title="Tải xuống"><i class="fa-solid fa-download"></i></button>
                                <button class="btn btn-sm btn-light text-danger shadow-sm rounded-3 px-2 py-1" title="Xóa"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-file-circle-xmark fs-1 mb-3 opacity-50"></i>
                            <p class="mb-0 fs-5">Chưa có tài liệu nào. Hãy upload lên để AI có thể học!</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
