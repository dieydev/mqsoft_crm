@{
    ViewData["Title"] = "Tổng quan (Dashboard)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Tổng quan hệ thống</h3>
    <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-medium">
        <i class="fa-solid fa-plus me-2"></i>Dự án mới
    </button>
</div>

<!-- Stats Row -->
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="glass-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-muted mb-0 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Tổng Khách hàng</h6>
                <div class="stat-icon bg-primary-light">
                    <i class="fa-solid fa-building"></i>
                </div>
            </div>
            <h3 class="fw-bold mb-1">@ViewBag.TotalCustomers</h3>
            <span class="badge bg-success-light"><i class="fa-solid fa-arrow-up me-1"></i>12%</span>
            <span class="text-muted small ms-1">so với tháng trước</span>
        </div>
    </div>
    
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="glass-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-muted mb-0 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Dự án Đang chạy</h6>
                <div class="stat-icon bg-warning-light">
                    <i class="fa-solid fa-spinner fa-spin-pulse"></i>
                </div>
            </div>
            <h3 class="fw-bold mb-1">@ViewBag.ActiveProjects</h3>
            <span class="badge bg-danger-light"><i class="fa-solid fa-arrow-down me-1"></i>2</span>
            <span class="text-muted small ms-1">chậm tiến độ</span>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="glass-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-muted mb-0 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Hợp đồng Mới</h6>
                <div class="stat-icon bg-success-light">
                    <i class="fa-solid fa-file-signature"></i>
                </div>
            </div>
            <h3 class="fw-bold mb-1">@ViewBag.TotalContracts</h3>
            <span class="badge bg-success-light"><i class="fa-solid fa-arrow-up me-1"></i>5%</span>
            <span class="text-muted small ms-1">so với tháng trước</span>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="glass-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-muted mb-0 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Truy vấn Chatbot</h6>
                <div class="stat-icon" style="background-color: rgba(236, 72, 153, 0.1); color: var(--secondary-color);">
                    <i class="fa-solid fa-robot"></i>
                </div>
            </div>
            <h3 class="fw-bold mb-1">@ViewBag.ChatbotQueries</h3>
            <span class="text-muted small">tổng số câu hỏi tháng này</span>
        </div>
    </div>
</div>

<!-- Charts & Tables Row -->
<div class="row g-4">
    <!-- Chart -->
    <div class="col-12 col-lg-8">
        <div class="glass-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Tiến độ Dự án & Doanh thu</h5>
                <select class="form-select form-select-sm w-auto border-0 bg-light text-muted fw-medium">
                    <option>6 Tháng qua</option>
                    <option>Năm nay</option>
                </select>
            </div>
            <canvas id="revenueChart" height="100"></canvas>
        </div>
    </div>
    
    <!-- Activity Feed -->
    <div class="col-12 col-lg-4">
        <div class="glass-card p-4 h-100 d-flex flex-column">
            <h5 class="fw-bold mb-4">Hoạt động gần đây</h5>
            
            @if (ViewBag.RecentActivities != null)
            {
                foreach (var activity in (List<AI_CRM.Domain.Entities.NhatKyHeThong>)ViewBag.RecentActivities)
                {
                    string iconClass = "fa-circle-info text-primary";
                    string bgClass = "bg-primary-light";
                    var actionUpper = activity.Action.ToUpper();
                    if (actionUpper.Contains("THÊM") || actionUpper.Contains("TẠO") || actionUpper.Contains("INSERT")) { iconClass = "fa-plus-circle text-success"; bgClass = "bg-success-light"; }
                    else if (actionUpper.Contains("SỬA") || actionUpper.Contains("CẬP NHẬT") || actionUpper.Contains("UPDATE")) { iconClass = "fa-pen-to-square text-warning"; bgClass = "bg-warning-light"; }
                    else if (actionUpper.Contains("XÓA") || actionUpper.Contains("LỖI") || actionUpper.Contains("DELETE")) { iconClass = "fa-triangle-exclamation text-danger"; bgClass = "bg-danger-light"; }
                    else if (actionUpper.Contains("ĐĂNG NHẬP") || actionUpper.Contains("LOGIN")) { iconClass = "fa-right-to-bracket text-info"; bgClass = "bg-info-light"; }

                    // Time formatting
                    var timeSpan = DateTime.Now - activity.Timestamp;
                    string timeStr = timeSpan.TotalMinutes < 60 ? $"{(int)timeSpan.TotalMinutes} phút trước" : 
                                     timeSpan.TotalHours < 24 ? $"{(int)timeSpan.TotalHours} giờ trước" : 
                                     $"{(int)timeSpan.TotalDays} ngày trước";

                    <div class="d-flex gap-3 mb-4">
                        <div class="stat-icon @bgClass shadow-sm" style="width: 45px; height: 45px; font-size: 1.1rem; flex-shrink: 0;">
                            <i class="fa-solid @iconClass"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold text-dark" style="font-size: 0.95rem;">@activity.Action</h6>
                            <p class="text-muted small mb-0 text-truncate" style="max-width: 200px;" title="@activity.Details">@activity.Details</p>
                            <p class="text-secondary mb-0" style="font-size: 0.75rem;">
                                @(activity.NguoiDung?.Username ?? "Hệ thống") • @timeStr
                            </p>
                        </div>
                    </div>
                }
            }
            
            <div class="mt-auto pt-3">
                <a href="@Url.Action("SystemLogs", "Admin")" class="btn btn-light text-primary fw-medium w-100 rounded-pill">Xem tất cả hoạt động</a>
            </div>
        </div>
    </div>
</div>
<!-- Additional Charts Row -->
<div class="row g-4 mt-1">
    <!-- Chart 1: Doughnut -->
    <div class="col-12 col-md-4">
        <div class="glass-card p-4 h-100">
            <h6 class="fw-bold mb-4">Trạng thái Dự án</h6>
            <div style="position: relative; height: 250px; width: 100%;">
                <canvas id="projectStatusChart"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Chart 2: Bar -->
    <div class="col-12 col-md-4">
        <div class="glass-card p-4 h-100">
            <h6 class="fw-bold mb-4">Top Hợp đồng Giá trị cao</h6>
            <div style="position: relative; height: 250px; width: 100%;">
                <canvas id="contractValueChart"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Chart 3: Polar Area -->
    <div class="col-12 col-md-4">
        <div class="glass-card p-4 h-100">
            <h6 class="fw-bold mb-4">Phân bổ Nhân sự</h6>
            <div style="position: relative; height: 250px; width: 100%;">
                <canvas id="employeeAllocationChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Data from server
        const revenueLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((System.Collections.Generic.Dictionary<string, decimal>)ViewBag.RevenueData).Keys));
        const revenueValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((System.Collections.Generic.Dictionary<string, decimal>)ViewBag.RevenueData).Values));
        
        const projectStatusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((System.Collections.Generic.Dictionary<string, int>)ViewBag.ProjectStatusData).Keys));
        const projectStatusValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((System.Collections.Generic.Dictionary<string, int>)ViewBag.ProjectStatusData).Values));

        const topContractLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((System.Collections.Generic.Dictionary<string, decimal>)ViewBag.TopContractsData).Keys));
        const topContractValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((System.Collections.Generic.Dictionary<string, decimal>)ViewBag.TopContractsData).Values));

        const employeeLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((System.Collections.Generic.Dictionary<string, int>)ViewBag.EmployeeAllocationData).Keys));
        const employeeValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((System.Collections.Generic.Dictionary<string, int>)ViewBag.EmployeeAllocationData).Values));

        // Common Options
        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        font: { family: "'Inter', sans-serif", size: 12 },
                        padding: 20
                    }
                },
                tooltip: {
                    padding: 12,
                    backgroundColor: 'rgba(15, 23, 42, 0.9)',
                    titleFont: { size: 13, family: "'Inter', sans-serif" },
                    bodyFont: { size: 14, family: "'Inter', sans-serif" },
                    cornerRadius: 8,
                }
            }
        };

        // 1. Line Chart: Revenue
        const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
        let gradient = ctxRevenue.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(79, 70, 229, 0.4)');
        gradient.addColorStop(1, 'rgba(79, 70, 229, 0.0)');

        new Chart(ctxRevenue, {
            type: 'line',
            data: {
                labels: revenueLabels.reverse(), // reverse to show from oldest to newest
                datasets: [{
                    label: 'Doanh thu (Triệu VNĐ)',
                    data: revenueValues.reverse(),
                    borderColor: '#4f46e5',
                    backgroundColor: gradient,
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#4f46e5',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: commonOptions.plugins.tooltip
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(0, 0, 0, 0.05)', drawBorder: false },
                        ticks: { font: { family: "'Inter', sans-serif" } }
                    },
                    x: {
                        grid: { display: false, drawBorder: false },
                        ticks: { font: { family: "'Inter', sans-serif" } }
                    }
                },
                interaction: { intersect: false, mode: 'index' },
            }
        });

        // 2. Doughnut Chart: Project Status
        const ctxProject = document.getElementById('projectStatusChart').getContext('2d');
        new Chart(ctxProject, {
            type: 'doughnut',
            data: {
                labels: projectStatusLabels.length > 0 ? projectStatusLabels : ['Chưa có DL'],
                datasets: [{
                    data: projectStatusValues.length > 0 ? projectStatusValues : [1],
                    backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#6366f1', '#ef4444', '#8b5cf6'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                ...commonOptions,
                cutout: '70%',
            }
        });

        // 3. Bar Chart: Contracts Value
        const ctxContract = document.getElementById('contractValueChart').getContext('2d');
        new Chart(ctxContract, {
            type: 'bar',
            data: {
                labels: topContractLabels.length > 0 ? topContractLabels : ['Chưa có DL'],
                datasets: [{
                    label: 'Giá trị (Tỷ VNĐ)',
                    data: topContractValues.length > 0 ? topContractValues : [0],
                    backgroundColor: 'rgba(16, 185, 129, 0.8)',
                    borderRadius: 6,
                    barThickness: 25
                }]
            },
            options: {
                ...commonOptions,
                plugins: {
                    ...commonOptions.plugins,
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(0, 0, 0, 0.05)' },
                        ticks: { font: { family: "'Inter', sans-serif", size: 11 } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { family: "'Inter', sans-serif", size: 11 } }
                    }
                }
            }
        });

        // 4. Polar Area Chart: Employee Allocation
        const ctxEmployee = document.getElementById('employeeAllocationChart').getContext('2d');
        new Chart(ctxEmployee, {
            type: 'polarArea',
            data: {
                labels: employeeLabels.length > 0 ? employeeLabels : ['Chưa có DL'],
                datasets: [{
                    data: employeeValues.length > 0 ? employeeValues : [1],
                    backgroundColor: [
                        'rgba(99, 102, 241, 0.7)',
                        'rgba(236, 72, 153, 0.7)',
                        'rgba(16, 185, 129, 0.7)',
                        'rgba(245, 158, 11, 0.7)',
                        'rgba(59, 130, 246, 0.7)'
                    ],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                ...commonOptions,
                scales: {
                    r: {
                        ticks: { display: false }
                    }
                }
            }
        });
    </script>
}
