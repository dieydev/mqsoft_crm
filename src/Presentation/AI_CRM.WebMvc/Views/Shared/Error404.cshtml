@{
    ViewData["Title"] = "Không tìm thấy trang";
    Layout = "_Layout";
}
<div class="container text-center mt-5 pt-5 mb-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="display-1 fw-bold text-primary mb-4">404</h1>
            <h2 class="mb-4">Ôi không! Trang bạn tìm kiếm không tồn tại.</h2>
            <p class="lead text-muted mb-5">
                Đường dẫn bạn truy cập có thể đã bị thay đổi, xóa bỏ, hoặc bạn đã nhập sai địa chỉ.
            </p>
            <a href="/" class="btn btn-primary rounded-pill px-4 py-2 mt-3 shadow-sm">
                <i class="fas fa-home me-2"></i> Trở về Trang chủ
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4 py-2 mt-3 ms-2 shadow-sm">
                <i class="fas fa-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>
</div>
