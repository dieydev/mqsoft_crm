@model IEnumerable<AI_CRM.Domain.Entities.LichSuHoiDap>
@{
    ViewData["Title"] = "Lịch sử Trợ lý AI";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-robot me-2" style="color: #ec4899;"></i>Lịch sử Hỏi đáp AI</h3>
    <a asp-action="Chat" class="btn rounded-pill px-4 py-2 shadow-sm fw-medium text-white d-flex align-items-center gap-2" style="background: linear-gradient(135deg, #6366f1, #ec4899); text-decoration: none;">
        <i class="fa-solid fa-wand-magic-sparkles"></i> Mở Chat ngay
    </a>
</div>

<div class="glass-card p-4 border-0 shadow-sm rounded-4" style="background: #fff;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted" style="font-size: 0.85rem; text-transform: uppercase;">
                <tr>
                    <th class="ps-4 py-3 fw-bold border-bottom-0">Người hỏi</th>
                    <th class="py-3 fw-bold border-bottom-0">Câu hỏi</th>
                    <th class="py-3 fw-bold border-bottom-0">AI Trả lời</th>
                    <th class="py-3 fw-bold border-bottom-0">Thời gian</th>
                    <th class="py-3 fw-bold border-bottom-0 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-bold text-primary">@(item.NguoiDung?.Username ?? "Tài khoản tạm")</td>
                            <td class="py-3 text-dark fw-medium" style="max-width: 300px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;" title="@item.Question">
                                <i class="fa-solid fa-user me-2 text-muted"></i>@item.Question
                            </td>
                            <td class="py-3 text-muted" style="max-width: 300px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;" title="@item.Answer">
                                <i class="fa-solid fa-robot me-2" style="color: #ec4899;"></i>@item.Answer
                            </td>
                            <td class="py-3 text-muted small">@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="py-3 text-end">
                                <form asp-action="DeleteHistory" asp-route-id="@item.ChatHistoryId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa lịch sử này?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash-can"></i> Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-comment-slash fs-1 mb-3 opacity-50"></i>
                            <p class="mb-0 fs-5">Chưa có lịch sử chat với AI.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
