@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi hệ thống";
    Layout = "_Layout"; 
}
<div class="container text-center mt-5 pt-5 mb-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="display-1 fw-bold text-danger"><i class="fas fa-exclamation-triangle"></i> 500</h1>
            <h2 class="mb-4">Đã xảy ra lỗi hệ thống!</h2>
            <p class="lead text-muted mb-5">
                Rất xin lỗi, hệ thống đang gặp sự cố khi xử lý yêu cầu của bạn. 
                Vui lòng thử lại sau hoặc chụp màn hình liên hệ quản trị viên.
            </p>
            @if (Model != null && Model.ShowRequestId)
            {
                <p class="text-muted"><small>Mã theo dõi (Request ID): <code>@Model.RequestId</code></small></p>
            }
            <a href="/" class="btn btn-primary rounded-pill px-4 py-2 mt-3 shadow-sm">
                <i class="fas fa-home me-2"></i> Trở về Trang chủ
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4 py-2 mt-3 ms-2 shadow-sm">
                <i class="fas fa-arrow-left me-2"></i> Quay lại trang trước
            </a>
        </div>
    </div>
</div>
