@{
    ViewData["Title"] = "Báo cáo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var customers = ViewBag.Customers as IEnumerable<AI_CRM.Domain.Entities.KhachHang> ?? new List<AI_CRM.Domain.Entities.KhachHang>();
    var projects = ViewBag.Projects as IEnumerable<AI_CRM.Domain.Entities.DuAn> ?? new List<AI_CRM.Domain.Entities.DuAn>();
    var contracts = ViewBag.Contracts as IEnumerable<AI_CRM.Domain.Entities.HopDong> ?? new List<AI_CRM.Domain.Entities.HopDong>();
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0 text-primary"><i class="fa-solid fa-chart-bar me-2"></i>Trung tâm Báo cáo</h2>
            <p class="text-muted">Xuất dữ liệu hệ thống ra định dạng Excel và PDF</p>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Xuất Danh sách Excel -->
        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-success text-white border-0 py-3">
                    <h5 class="card-title mb-0"><i class="fa-solid fa-file-excel me-2"></i>Xuất Excel (Danh sách)</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                            <div>
                                <h6 class="mb-1">Danh sách Khách hàng</h6>
                                <small class="text-muted">Xuất toàn bộ thông tin khách hàng đang quản lý</small>
                            </div>
                            <a href="@Url.Action("ExportCustomersExcel", "Report")" class="btn btn-outline-success btn-sm rounded-pill px-4 text-nowrap">
                                <i class="fa-solid fa-download me-1"></i> Tải về
                            </a>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                            <div>
                                <h6 class="mb-1">Danh sách Dự án</h6>
                                <small class="text-muted">Xuất thông tin tất cả các dự án và trạng thái</small>
                            </div>
                            <a href="@Url.Action("ExportProjectsExcel", "Report")" class="btn btn-outline-success btn-sm rounded-pill px-4 text-nowrap">
                                <i class="fa-solid fa-download me-1"></i> Tải về
                            </a>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                            <div>
                                <h6 class="mb-1">Danh sách Hợp đồng</h6>
                                <small class="text-muted">Xuất thông tin tất cả hợp đồng và giá trị</small>
                            </div>
                            <a href="@Url.Action("ExportContractsExcel", "Report")" class="btn btn-outline-success btn-sm rounded-pill px-4 text-nowrap">
                                <i class="fa-solid fa-download me-1"></i> Tải về
                            </a>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-bottom-0">
                            <div>
                                <h6 class="mb-1">Danh sách Người dùng</h6>
                                <small class="text-muted">Xuất thông tin tài khoản và phân quyền</small>
                            </div>
                            <a href="@Url.Action("ExportUsersExcel", "Report")" class="btn btn-outline-success btn-sm rounded-pill px-4 text-nowrap">
                                <i class="fa-solid fa-download me-1"></i> Tải về
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Xuất Báo cáo PDF -->
        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-danger text-white border-0 py-3">
                    <h5 class="card-title mb-0"><i class="fa-solid fa-file-pdf me-2"></i>Xuất PDF (Chi tiết)</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        
                        <div class="list-group-item px-0 py-3 border-0">
                            <form action="@Url.Action("ExportCustomerPdf", "Report")" method="get" class="d-flex align-items-center w-100">
                                <div class="flex-grow-1 me-3">
                                    <label class="form-label mb-1">Báo cáo Khách hàng</label>
                                    <select name="id" class="form-select form-select-sm" required>
                                        <option value="">-- Chọn khách hàng --</option>
                                        @foreach (var c in customers)
                                        {
                                            <option value="@c.CustomerId">@c.CompanyName (@c.Representative)</option>
                                        }
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-4 mt-4 text-nowrap">
                                    <i class="fa-solid fa-download me-1"></i> Xuất PDF
                                </button>
                            </form>
                        </div>

                        <div class="list-group-item px-0 py-3 border-0">
                            <form action="@Url.Action("ExportProjectPdf", "Report")" method="get" class="d-flex align-items-center w-100">
                                <div class="flex-grow-1 me-3">
                                    <label class="form-label mb-1">Báo cáo Dự án</label>
                                    <select name="id" class="form-select form-select-sm" required>
                                        <option value="">-- Chọn dự án --</option>
                                        @foreach (var p in projects)
                                        {
                                            <option value="@p.ProjectId">@p.ProjectName</option>
                                        }
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-4 mt-4 text-nowrap">
                                    <i class="fa-solid fa-download me-1"></i> Xuất PDF
                                </button>
                            </form>
                        </div>

                        <div class="list-group-item px-0 py-3 border-0">
                            <form action="@Url.Action("ExportContractPdf", "Report")" method="get" class="d-flex align-items-center w-100">
                                <div class="flex-grow-1 me-3">
                                    <label class="form-label mb-1">Báo cáo Hợp đồng</label>
                                    <select name="id" class="form-select form-select-sm" required>
                                        <option value="">-- Chọn hợp đồng --</option>
                                        @foreach (var hd in contracts)
                                        {
                                            <option value="@hd.ContractId">@hd.ContractName</option>
                                        }
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-4 mt-4 text-nowrap">
                                    <i class="fa-solid fa-download me-1"></i> Xuất PDF
                                </button>
                            </form>
                        </div>

                        <div class="list-group-item px-0 py-3 border-0">
                            <form action="@Url.Action("ExportProgressPdf", "Report")" method="get" class="d-flex align-items-center w-100">
                                <div class="flex-grow-1 me-3">
                                    <label class="form-label mb-1">Báo cáo Tiến độ (chọn Dự án)</label>
                                    <select name="id" class="form-select form-select-sm" required>
                                        <option value="">-- Chọn dự án --</option>
                                        @foreach (var p in projects)
                                        {
                                            <option value="@p.ProjectId">@p.ProjectName</option>
                                        }
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-4 mt-4 text-nowrap">
                                    <i class="fa-solid fa-download me-1"></i> Xuất PDF
                                </button>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
