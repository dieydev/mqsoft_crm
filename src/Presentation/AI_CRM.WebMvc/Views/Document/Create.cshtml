@model AI_CRM.Domain.Entities.TaiLieuNoiBo
@{
    ViewData["Title"] = "Tải lên Tài liệu";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-cloud-arrow-up me-2 text-primary"></i>Tải lên Tài liệu Mới</h3>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="Title" class="form-label fw-bold">Tên tài liệu <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" required placeholder="Nhập tên tài liệu..." />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Tệp đính kèm <span class="text-danger">*</span></label>
                        <input type="file" name="uploadFile" class="form-control" required accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt" />
                        <span class="text-danger small">@Html.ValidationMessage("FilePath")</span>
                        <div class="form-text">Hỗ trợ các định dạng: PDF, Word, Excel, PowerPoint, Text. (Tối đa 20MB)</div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label fw-bold">Nhóm tài liệu <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId" required>
                            <option value="">-- Chọn nhóm tài liệu --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Gắn thẻ (Tags)</label>
                        <input type="text" name="TagsInput" class="form-control" placeholder="Tag1, Tag2, QuyTrinh, ..." />
                        <div class="form-text">Nhập các tag cách nhau bởi dấu phẩy (,).</div>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả thêm</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả tóm tắt nội dung tài liệu..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="IsProcessedForAI" class="form-check-input" type="checkbox" role="switch">
                            <label class="form-check-label fw-bold text-primary" asp-for="IsProcessedForAI">
                                <i class="fa-solid fa-robot me-1"></i> Đưa vào dữ liệu học cho Trợ lý AI (RAG)
                            </label>
                        </div>
                        <div class="form-text">Nếu bật, nội dung tài liệu sẽ được phân tích và lưu vào Vector Database để Chatbot có thể tìm kiếm và trả lời.</div>
                    </div>
                </div>

                <hr class="my-4 text-muted">
                <div class="text-end">
                    <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm fw-bold">
                        <i class="fa-solid fa-upload me-2"></i> Tải lên
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
