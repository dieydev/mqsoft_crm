@model AI_CRM.Domain.Entities.HopDong
@{
    ViewData["Title"] = "Thêm mới Hợp đồng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-file-contract me-2 text-primary"></i>Thêm Hợp đồng mới</h3>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
    </a>
</div>

<div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Khách hàng <span class="text-danger">*</span></label>
                <select asp-for="CustomerId" class="form-select bg-light border-0 shadow-none rounded-3 py-2" asp-items="ViewBag.CustomerId" required>
                    <option value="">-- Chọn khách hàng --</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Số hợp đồng <span class="text-danger">*</span></label>
                <input asp-for="ContractNumber" class="form-control bg-light border-0 shadow-none rounded-3 py-2" placeholder="VD: HD-2026-001" required />
                <span asp-validation-for="ContractNumber" class="text-danger small"></span>
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">Tên hợp đồng <span class="text-danger">*</span></label>
                <input asp-for="ContractName" class="form-control bg-light border-0 shadow-none rounded-3 py-2" placeholder="Nhập tên hợp đồng..." required />
                <span asp-validation-for="ContractName" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Giá trị hợp đồng (VNĐ)</label>
                <input asp-for="ContractValue" type="number" class="form-control bg-light border-0 shadow-none rounded-3 py-2" placeholder="VD: 50000000">
                <span asp-validation-for="ContractValue" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Trạng thái <span class="text-danger">*</span></label>
                <select asp-for="StatusId" class="form-select bg-light border-0 shadow-none rounded-3 py-2" asp-items="ViewBag.StatusId" required>
                    <option value="">-- Chọn trạng thái --</option>
                </select>
                <span asp-validation-for="StatusId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Ngày ký</label>
                <input asp-for="SignDate" type="date" class="form-control bg-light border-0 shadow-none rounded-3 py-2">
                <span asp-validation-for="SignDate" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted small text-uppercase">Ngày hết hạn</label>
                <input asp-for="ExpireDate" type="date" class="form-control bg-light border-0 shadow-none rounded-3 py-2">
                <span asp-validation-for="ExpireDate" class="text-danger small"></span>
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted small text-uppercase">File đính kèm (PDF)</label>
                <input type="file" name="pdfFile" class="form-control bg-light border-0 shadow-none rounded-3 py-2" accept=".pdf">
            </div>
            <div class="col-12 text-end mt-4">
                <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">
                    <i class="fa-solid fa-save me-2"></i> Lưu Hợp đồng
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
