@model AI_CRM.Domain.Entities.KhachHang
@{
    ViewData["Title"] = "Chi tiết Khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-address-card me-2 text-primary"></i>Hồ sơ Khách hàng</h3>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.CustomerId" class="btn btn-warning rounded-pill px-4 shadow-sm fw-medium me-2">
            <i class="fa-solid fa-pen me-2"></i> Sửa
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
            <i class="fa-solid fa-arrow-left me-2"></i> Trở về
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: Info -->
    <div class="col-lg-4">
        <div class="glass-card p-4 border-0 shadow-sm rounded-4 h-100 bg-white text-center">
            @{ var firstChar = !string.IsNullOrEmpty(Model?.CompanyName) ? Model.CompanyName.Substring(0, 1).ToUpper() : "C"; }
            <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm mx-auto mb-3" style="width: 100px; height: 100px; font-weight: 700; font-size: 3rem;">
                @firstChar
            </div>
            <h4 class="fw-bold text-dark mb-1">@Model?.CompanyName</h4>
            <p class="text-muted mb-3">@Model?.CustomerCode</p>
            
            @if (Model?.IsDeleted == true)
            {
                <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="fa-solid fa-ban me-1"></i> Ngừng hoạt động</span>
            }
            else
            {
                <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fa-solid fa-check me-1"></i> Đang hoạt động</span>
            }

            <hr class="my-4 text-muted">

            <div class="text-start">
                <div class="mb-3">
                    <small class="text-muted d-block text-uppercase fw-bold mb-1" style="font-size: 0.75rem;">Người đại diện</small>
                    <div class="fw-medium text-dark"><i class="fa-regular fa-user me-2 text-primary"></i>@(string.IsNullOrEmpty(Model?.Representative) ? "Chưa cập nhật" : Model.Representative)</div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block text-uppercase fw-bold mb-1" style="font-size: 0.75rem;">Số điện thoại</small>
                    <div class="fw-medium text-dark"><i class="fa-solid fa-phone me-2 text-success"></i>@(string.IsNullOrEmpty(Model?.Phone) ? "Chưa cập nhật" : Model.Phone)</div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block text-uppercase fw-bold mb-1" style="font-size: 0.75rem;">Email</small>
                    <div class="fw-medium text-dark"><i class="fa-regular fa-envelope me-2 text-warning"></i>@(string.IsNullOrEmpty(Model?.Email) ? "Chưa cập nhật" : Model.Email)</div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block text-uppercase fw-bold mb-1" style="font-size: 0.75rem;">Địa chỉ</small>
                    <div class="fw-medium text-dark"><i class="fa-solid fa-location-dot me-2 text-danger"></i>@(string.IsNullOrEmpty(Model?.Address) ? "Chưa cập nhật" : Model.Address)</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Stats & Related Data -->
    <div class="col-lg-8">
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white d-flex align-items-center">
                    <div class="bg-primary-light p-3 rounded-3 me-3">
                        <i class="fa-solid fa-file-contract fs-3 text-primary"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.75rem;">Hợp đồng đã ký</h6>
                        <h3 class="fw-bold mb-0">@(Model?.HopDongs?.Count ?? 0)</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white d-flex align-items-center">
                    <div class="bg-success-light p-3 rounded-3 me-3">
                        <i class="fa-solid fa-project-diagram fs-3 text-success"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.75rem;">Dự án phần mềm</h6>
                        <h3 class="fw-bold mb-0">@(Model?.DuAns?.Count ?? 0)</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="glass-card p-4 border-0 shadow-sm rounded-4 bg-white">
            <h5 class="fw-bold mb-3">Ghi chú khách hàng</h5>
            <div class="bg-light p-3 rounded-3 border">
                @if (string.IsNullOrEmpty(Model?.Note))
                {
                    <span class="text-muted fst-italic">Không có ghi chú nào.</span>
                }
                else
                {
                    <p class="mb-0 text-dark" style="white-space: pre-wrap;">@Model.Note</p>
                }
            </div>
        </div>
    </div>
</div>
