@{
    ViewData["Title"] = "Lưu trữ truyền tải ảnh (RIS-PACS)";
    Layout = "_UserLayout";
}

<div class="container py-5 mt-5">
    <div class="text-center mb-5 pb-4" data-aos="fade-up">
        <h2 class="fw-bold text-uppercase mb-4" style="color: #3876a5; font-family: var(--font-heading); font-size: 2.2rem;">Lưu Trữ & Truyền Tải Ảnh (RIS-PACS)</h2>
        <div class="mx-auto" style="max-width: 950px;">
            <p class="fs-6 text-dark mb-3" style="line-height: 1.8; text-align: center;">
                Hệ thống lưu trữ và truyền tải hình ảnh y tế chuẩn DICOM, hỗ trợ bác sĩ chẩn đoán hình ảnh từ xa với tốc độ cao, độ nét chuẩn xác, không cần in phim giấy.
            </p>
        </div>
    </div>

    <div class="row align-items-center g-5">
        <div class="col-lg-7" data-aos="fade-right" data-aos-delay="100">
            <div class="d-flex mb-4 pb-3">
                <div class="flex-shrink-0 me-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; border: 2px solid #3876a5; background-color: #f3f0ff;">
                        <i class="fa-solid fa-x-ray fa-2x" style="color: #3876a5;"></i>
                    </div>
                </div>
                <div>
                    <h4 class="fw-bold mb-2" style="color: #3876a5;">Truyền hình ảnh tốc độ cao</h4>
                    <p class="text-muted mb-0" style="line-height: 1.7; text-align: justify;">
                        Tốc độ truyền tải file ảnh DICOM mượt mà, hỗ trợ 3D reconstruction, MIP, MPR trực tiếp trên trình duyệt web mà không cần cài đặt phần mềm nặng trên máy trạm.
                    </p>
                </div>
            </div>

            <div class="d-flex mb-4 pb-3">
                <div class="flex-shrink-0 me-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; border: 2px solid #3876a5; background-color: #e3f2fd;">
                        <i class="fa-solid fa-network-wired fa-2x" style="color: #3876a5;"></i>
                    </div>
                </div>
                <div>
                    <h4 class="fw-bold mb-2" style="color: #3876a5;">Hội chẩn y tế từ xa (Teleradiology)</h4>
                    <p class="text-muted mb-0" style="line-height: 1.7; text-align: justify;">
                        Kết nối các bác sĩ chuyên khoa ở các bệnh viện khác nhau để cùng hội chẩn trên một bệnh án hình ảnh, nâng cao độ chính xác và rút ngắn thời gian chẩn đoán.
                    </p>
                </div>
            </div>

            <div class="d-flex">
                <div class="flex-shrink-0 me-4">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; border: 2px solid #3876a5; background-color: #e0f7fa;">
                        <i class="fa-solid fa-leaf fa-2x" style="color: #3876a5;"></i>
                    </div>
                </div>
                <div>
                    <h4 class="fw-bold mb-2" style="color: #3876a5;">Tiết kiệm & Bảo vệ môi trường</h4>
                    <p class="text-muted mb-0" style="line-height: 1.7; text-align: justify;">
                        Loại bỏ hoàn toàn phim nhựa (phim X-quang, CT, MRI truyền thống), vừa giảm thiểu chi phí vật tư y tế, vừa đóng góp tích cực vào việc bảo vệ môi trường xanh.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-5 text-center" data-aos="fade-left" data-aos-delay="200">
            <img src="/images/Dichvu/services-seo-alt-colors-optimized.png" alt="RIS-PACS" class="img-fluid rounded-4 shadow-lg border border-4 border-white" style="object-fit: contain; background-color:#5bb3e5; padding: 2rem;">
        </div>
    </div>
</div>
